---
import { ChevronDown } from "@lucide/astro";
import { getCollection } from "astro:content";

const faqs = (await getCollection("faqs")).sort((a, b) => a.data.order - b.data.order);
---

<section id="faq" class="faq-section relative overflow-hidden bg-[#f7f4ee] py-16 sm:py-20 lg:py-24">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-16 bg-[radial-gradient(circle_at_15%_0%,rgba(255,255,255,0.98),rgba(255,255,255,0)_42%),radial-gradient(circle_at_50%_0%,rgba(255,255,255,0.94),rgba(255,255,255,0)_44%),radial-gradient(circle_at_85%_0%,rgba(255,255,255,0.98),rgba(255,255,255,0)_42%)] opacity-95"></div>
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-16 rotate-180 bg-[radial-gradient(circle_at_15%_0%,rgba(255,255,255,0.98),rgba(255,255,255,0)_42%),radial-gradient(circle_at_50%_0%,rgba(255,255,255,0.94),rgba(255,255,255,0)_44%),radial-gradient(circle_at_85%_0%,rgba(255,255,255,0.98),rgba(255,255,255,0)_42%)] opacity-95"></div>

  <div class="relative mx-auto max-w-6xl px-6 md:px-16 lg:px-24">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-slate-500">FAQ</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-slate-800 sm:text-4xl lg:text-[2.85rem]">
        Questions travelers ask most
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-sm leading-7 text-slate-600 sm:text-base">
        Quick answers to common questions about packages, guides, transfers, and booking.
      </p>
    </div>

    <div class="mx-auto mt-10 max-w-4xl space-y-4">
      {
        faqs.map((faq, index) => (
          <article
            class="faq-item rounded-[1.4rem] border border-slate-200 bg-white shadow-[0_12px_30px_rgba(15,23,42,0.06)] transition-shadow duration-300 hover:shadow-[0_16px_34px_rgba(15,23,42,0.09)]"
            data-open={index === 0 ? "true" : "false"}
          >
            <button
              type="button"
              class="faq-trigger flex w-full items-center justify-between gap-4 px-5 py-5 text-left sm:px-6"
              aria-expanded={index === 0 ? "true" : "false"}
            >
              <span class="text-base font-semibold tracking-tight text-slate-800 sm:text-[1.05rem]">
                {faq.data.question}
              </span>
              <span class="faq-icon inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-slate-100 text-slate-600 transition-transform duration-300">
                <ChevronDown class="h-5 w-5" aria-hidden="true" />
              </span>
            </button>

            <div
              class={`faq-panel overflow-hidden transition-[max-height,opacity] duration-300 ease-out ${
                index === 0 ? "max-h-[16rem] opacity-100" : "max-h-0 opacity-0"
              }`}
            >
              <div class="px-5 pb-5 sm:px-6">
                <p class="max-w-3xl text-sm leading-7 text-slate-600 sm:text-[0.98rem]">
                  {faq.data.answer}
                </p>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<script>
  const items = Array.from(document.querySelectorAll(".faq-item"));

  const closeItem = (item) => {
    const trigger = item.querySelector(".faq-trigger");
    const panel = item.querySelector(".faq-panel");
    const icon = item.querySelector(".faq-icon");

    item.dataset.open = "false";
    trigger?.setAttribute("aria-expanded", "false");
    panel?.classList.remove("max-h-[16rem]", "opacity-100");
    panel?.classList.add("max-h-0", "opacity-0");
    icon?.classList.remove("rotate-180");
  };

  const openItem = (item) => {
    const trigger = item.querySelector(".faq-trigger");
    const panel = item.querySelector(".faq-panel");
    const icon = item.querySelector(".faq-icon");

    item.dataset.open = "true";
    trigger?.setAttribute("aria-expanded", "true");
    panel?.classList.remove("max-h-0", "opacity-0");
    panel?.classList.add("max-h-[16rem]", "opacity-100");
    icon?.classList.add("rotate-180");
  };

  items.forEach((item) => {
    const trigger = item.querySelector(".faq-trigger");

    if (item.dataset.open === "true") {
      const icon = item.querySelector(".faq-icon");
      icon?.classList.add("rotate-180");
      const panel = item.querySelector(".faq-panel");
      panel?.classList.add("max-h-[16rem]", "opacity-100");
    }

    trigger?.addEventListener("click", () => {
      const isOpen = item.dataset.open === "true";

      items.forEach((other) => {
        if (other !== item) closeItem(other);
      });

      if (isOpen) {
        closeItem(item);
      } else {
        openItem(item);
      }
    });
  });
</script>

<style>
  .faq-section {
    isolation: isolate;
  }
</style>
