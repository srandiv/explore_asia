---
import { ChevronDown } from "@lucide/astro";
import { getCollection } from "astro:content";

const faqs = (await getCollection("faqs")).sort((a, b) => a.data.order - b.data.order);
---

<section id="faq" class="faq-section site-section relative overflow-hidden bg-white">
  <div class="section-container relative">
    <div class="section-heading" data-animate="fade-up">
      <p>FAQ</p>
      <h2>
        Questions travelers ask most
      </h2>
      <p>
        Quick answers to common questions about packages, guides, transfers, and booking.
      </p>
    </div>

    <div class="mx-auto mt-10 max-w-4xl space-y-4">
      {
        faqs.map((faq, index) => (
          <article
            class="faq-item rounded-lg border border-brand-secondary/20 bg-white shadow-[0_14px_34px_rgba(27,156,80,0.08)] transition duration-300 hover:-translate-y-0.5 hover:border-brand-secondary/45 hover:shadow-[0_18px_42px_rgba(27,156,80,0.14)]"
            data-open={index === 0 ? "true" : "false"}
            data-animate="fade-left"
            data-animate-delay={`${Math.min(index, 4) * 0.08}`}
          >
            <button
              type="button"
              class="faq-trigger flex w-full items-center justify-between gap-4 px-5 py-5 text-left sm:px-6"
              aria-expanded={index === 0 ? "true" : "false"}
            >
              <span>
                {faq.data.question}
              </span>
              <span class="faq-icon inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-secondary text-white shadow-[0_12px_24px_rgba(27,156,80,0.2)] transition duration-300">
                <ChevronDown class="h-5 w-5" aria-hidden="true" />
              </span>
            </button>

            <div
              class={`faq-panel overflow-hidden transition-[max-height,opacity] duration-300 ease-out ${
                index === 0 ? "max-h-[16rem] opacity-100" : "max-h-0 opacity-0"
              }`}
            >
              <div class="px-5 pb-5 sm:px-6">
                <p>
                  {faq.data.answer}
                </p>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<script>
  const items = Array.from(document.querySelectorAll(".faq-item"));

  const closeItem = (item) => {
    const trigger = item.querySelector(".faq-trigger");
    const panel = item.querySelector(".faq-panel");
    const icon = item.querySelector(".faq-icon");

    item.dataset.open = "false";
    trigger?.setAttribute("aria-expanded", "false");
    panel?.classList.remove("max-h-[16rem]", "opacity-100");
    panel?.classList.add("max-h-0", "opacity-0");
    icon?.classList.remove("rotate-180");
  };

  const openItem = (item) => {
    const trigger = item.querySelector(".faq-trigger");
    const panel = item.querySelector(".faq-panel");
    const icon = item.querySelector(".faq-icon");

    item.dataset.open = "true";
    trigger?.setAttribute("aria-expanded", "true");
    panel?.classList.remove("max-h-0", "opacity-0");
    panel?.classList.add("max-h-[16rem]", "opacity-100");
    icon?.classList.add("rotate-180");
  };

  items.forEach((item) => {
    const trigger = item.querySelector(".faq-trigger");

    if (item.dataset.open === "true") {
      const icon = item.querySelector(".faq-icon");
      icon?.classList.add("rotate-180");
      const panel = item.querySelector(".faq-panel");
      panel?.classList.add("max-h-[16rem]", "opacity-100");
    }

    trigger?.addEventListener("click", () => {
      const isOpen = item.dataset.open === "true";

      items.forEach((other) => {
        if (other !== item) closeItem(other);
      });

      if (isOpen) {
        closeItem(item);
      } else {
        openItem(item);
      }
    });
  });
</script>

<style>
  .faq-section {
    isolation: isolate;
  }

  .faq-item {
    position: relative;
    overflow: hidden;
  }

  .faq-item::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 4px;
    background: linear-gradient(90deg, rgba(27, 156, 80, 0.45), #1b9c50);
    opacity: 0;
    transition: opacity 300ms ease;
  }

  .faq-item[data-open="true"]::before,
  .faq-item:hover::before {
    opacity: 1;
  }

  .faq-item[data-open="true"] .faq-icon,
  .faq-item:hover .faq-icon {
    background-color: #157f43;
    color: #ffffff;
  }
</style>
