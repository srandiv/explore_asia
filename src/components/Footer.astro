---
import logo from "../assets/logo.png";
import { Clock } from "@lucide/astro";
import { destinationLinks, footerQuickLinks, packageLinks, servicesLinks } from "../lib/navigation";

const year = new Date().getFullYear();
---

<footer class="relative overflow-hidden bg-[#0d1b2a] text-white">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(201,168,76,0.16),transparent_35%),radial-gradient(circle_at_top_right,rgba(255,255,255,0.08),transparent_28%)]"></div>

  <div class="relative mx-auto max-w-7xl px-6 py-16 md:px-16 lg:px-24">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_3.2fr] lg:gap-12">
      <div class="footer-copy space-y-5">
        <a href="/" class="inline-flex items-center" aria-label="Explore Asia home">
          <img src={logo.src} alt="Explore Asia" class="h-20 w-auto object-contain sm:h-24" />
        </a>
        <p>
          Curated Sri Lanka journeys, trusted local guidance, and flexible trip planning for holidays that feel effortless.
        </p>
        <div class="footer-clock" data-sri-lanka-clock>
          <span class="footer-clock__icon" aria-hidden="true">
            <Clock size={18} stroke-width={1.8} />
          </span>
          <span>
            <span class="footer-clock__label">Sri Lanka Time</span>
            <time class="footer-clock__time" data-sri-lanka-clock-time datetime="">--:--:--</time>
            <span class="footer-clock__date" data-sri-lanka-clock-date>Colombo, Sri Lanka</span>
          </span>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-x-6 gap-y-10 sm:gap-x-10 lg:grid-cols-5">
        <div class="footer-column">
          <h2>Quick Links</h2>
          <ul class="mt-5 space-y-3 text-sm text-white/82">
            {
              footerQuickLinks.map((link) => (
                <li>
                  <a href={link.href} class="transition-colors hover:text-brand-gold">
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="footer-column">
          <h2>Services</h2>
          <ul class="mt-5 space-y-3 text-sm text-white/82">
            {
              servicesLinks.map((link) => (
                <li>
                  <a href={link.href} class="transition-colors hover:text-brand-gold">
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="footer-column">
          <h2>Packages</h2>
          <ul class="mt-5 space-y-3 text-sm text-white/82">
            {
              packageLinks.map((link) => (
                <li>
                  <a href={link.href} class="transition-colors hover:text-brand-gold">
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="footer-column">
          <h2>Destinations</h2>
          <ul class="mt-5 space-y-3 text-sm text-white/82">
            {
              destinationLinks.map((link) => (
                <li>
                  <a href={link.href} class="transition-colors hover:text-brand-gold">
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="footer-column">
          <h2>Legal</h2>
          <ul class="mt-5 space-y-3 text-sm text-white/82">
            <li>
              <a href="/terms-and-conditions" class="transition-colors hover:text-brand-gold">
                Terms and Conditions
              </a>
            </li>
            <li>
              <a href="/privacy-policy" class="transition-colors hover:text-brand-gold">
                Privacy Policy
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-bottom mt-12 flex flex-col gap-3 border-t border-white/10 pt-6 sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} Explore Asia. All rights reserved.</p>
      <p>
        Powered by{" "}
        <a href="https://buggyless.com" class="font-bold text-white transition-colors hover:text-brand-secondary" target="_blank" rel="noreferrer">
          Buggyless
        </a>
      </p>
    </div>
  </div>
</footer>

<script>
  const sriLankaClock = document.querySelector("[data-sri-lanka-clock]");

  if (sriLankaClock) {
    const timeElement = sriLankaClock.querySelector("[data-sri-lanka-clock-time]");
    const dateElement = sriLankaClock.querySelector("[data-sri-lanka-clock-date]");

    const timeFormatter = new Intl.DateTimeFormat("en-US", {
      timeZone: "Asia/Colombo",
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
      hour12: true,
    });

    const dateFormatter = new Intl.DateTimeFormat("en-US", {
      timeZone: "Asia/Colombo",
      weekday: "short",
      month: "short",
      day: "numeric",
      year: "numeric",
    });

    const isoFormatter = new Intl.DateTimeFormat("en-CA", {
      timeZone: "Asia/Colombo",
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
      hour12: false,
    });

    const updateSriLankaClock = () => {
      const now = new Date();

      if (timeElement instanceof HTMLTimeElement) {
        timeElement.textContent = timeFormatter.format(now);
        timeElement.dateTime = isoFormatter.format(now).replace(", ", "T");
      }

      if (dateElement) {
        dateElement.textContent = `${dateFormatter.format(now)} - Colombo`;
      }
    };

    updateSriLankaClock();
    window.setInterval(updateSriLankaClock, 1000);
  }
</script>

<style>
  .footer-clock {
    display: inline-flex;
    width: min(100%, 18rem);
    align-items: center;
    gap: 0.8rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 0.9rem;
    background: rgba(255, 255, 255, 0.08);
    padding: 0.85rem 0.95rem;
    color: #fff;
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.18);
  }

  .footer-clock__icon {
    display: inline-flex;
    height: 2.35rem;
    width: 2.35rem;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: rgba(201, 168, 76, 0.16);
    color: #d8b65a;
  }

  .footer-clock__label,
  .footer-clock__date {
    display: block;
    font-size: 0.72rem;
    line-height: 1.35;
    color: rgba(255, 255, 255, 0.58);
  }

  .footer-clock__label {
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  .footer-clock__time {
    display: block;
    margin-top: 0.12rem;
    font-size: 1.05rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.04em;
    line-height: 1.25;
    color: #fff;
  }
</style>
