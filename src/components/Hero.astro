---
import { ArrowLeft, ArrowRight } from '@lucide/astro';
import Navbar from './Navbar.astro';
import galleFortImg from '../assets/images/ hero/chathura-indika-laj-xlhp6rs-unsplash.webp';
import adamsPeakImg from '../assets/images/ hero/malith-d-karunarathne--pw-saa99lw-unsplash.webp';
import elephantImg from '../assets/images/ hero/paul-kapischka-43fxbr3mqoy-unsplash.webp';
import kandyPeraheraImg from '../assets/images/ hero/yves-alarie-yagheetusk4-unsplash.webp';

const slides = [
  {
    image: galleFortImg,
    title: 'GALLE FORT',
    subtitle: "Sunset streets, rampart views, and colonial charm inside Sri Lanka's storied southern fort.",
  },
  {
    image: adamsPeakImg,
    title: "ADAM'S PEAK",
    subtitle: "Follow the lantern-lit trail before dawn and watch first light rise over the central highlands.",
  },
  {
    image: elephantImg,
    title: 'ELEPHANT ENCOUNTERS',
    subtitle: "Meet Sri Lanka's gentle giants through thoughtful wildlife moments shaped by care and respect.",
  },
  {
    image: kandyPeraheraImg,
    title: 'KANDY PERAHERA',
    subtitle: "Feel the rhythm of drums, dancers, and torchlight in one of the island's richest cultural nights.",
  },
];

---

<div id="hero-wrapper" class="hero-section relative h-screen w-full overflow-hidden">
  <Navbar />

  <!-- ===== SWIPER SLIDES ===== -->
  <div class="swiper hero-swiper h-full w-full">
    <div class="swiper-wrapper">
      {
        slides.map((slide, i) => (
          <div class="swiper-slide relative">
            <img
              src={slide.image.src}
              alt={slide.title}
              class="absolute inset-0 h-full w-full object-cover"
              fetchpriority={i === 0 ? 'high' : 'lazy'}
            />
            <!-- Overlay -->
            <div class="absolute inset-0 bg-black/40"></div>

            <!-- Slide content -->
            <div class="absolute inset-0 z-10 flex items-center">
              <div class="w-full px-6 md:px-16 lg:px-24">
                <div class="hero-copy" data-animate="fade-up" data-animate-trigger="load" data-animate-delay="0.15" data-animate-duration="1">
                  <h2>
                    {slide.title}
                  </h2>
                  <p>
                    {slide.subtitle}
                  </p>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <!-- ===== SOCIAL MEDIA SIDEBAR ===== -->
  <div class="absolute right-6 md:right-16 lg:right-24 top-1/2 z-20 hidden -translate-y-1/2 flex-col items-center gap-8 md:flex">
    <a
      href="https://instagram.com"
      target="_blank"
      rel="noopener"
      class="vertical-text group inline-flex items-center gap-2 text-[8px] font-semibold uppercase tracking-[0.18em] text-white/70 transition-colors hover:text-white"
      aria-label="Instagram"
    >
      <svg class="social-icon h-3 w-3 transition-transform group-hover:scale-110" aria-hidden="true" viewBox="0 0 24 24" fill="none">
        <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="2"></rect>
        <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"></circle>
        <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"></circle>
      </svg>
      <span>Instagram</span>
    </a>
    <a
      href="https://twitter.com"
      target="_blank"
      rel="noopener"
      class="vertical-text group inline-flex items-center gap-2 text-[8px] font-semibold uppercase tracking-[0.18em] text-white/70 transition-colors hover:text-white"
      aria-label="Twitter"
    >
      <svg class="social-icon h-3 w-3 transition-transform group-hover:scale-110" aria-hidden="true" viewBox="0 0 16 16" fill="currentColor">
        <path d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.142 0-.284-.009-.425A6.681 6.681 0 0 0 16 3.542a6.578 6.578 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03 9.325 9.325 0 0 1 1.108 2.6a3.289 3.289 0 0 0 1.016 4.381A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.633 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.618-.059 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58 6.32 6.32 0 0 1 0 13.535 9.344 9.344 0 0 0 5.026 15Z"></path>
      </svg>
      <span>Twitter</span>
    </a>
    <a
      href="https://facebook.com"
      target="_blank"
      rel="noopener"
      class="vertical-text group inline-flex items-center gap-2 text-[8px] font-semibold uppercase tracking-[0.18em] text-white/70 transition-colors hover:text-white"
      aria-label="Facebook"
    >
      <svg class="social-icon h-3 w-3 transition-transform group-hover:scale-110" aria-hidden="true" viewBox="0 0 24 24" fill="currentColor">
        <path d="M22 12.06C22 6.505 17.523 2 12 2S2 6.505 2 12.06c0 5.02 3.657 9.184 8.438 9.94v-7.03H7.898v-2.91h2.54V9.845c0-2.522 1.492-3.915 3.777-3.915 1.094 0 2.238.197 2.238.197v2.476h-1.26c-1.243 0-1.63.776-1.63 1.572v1.886h2.773l-.443 2.91h-2.33V22C18.343 21.244 22 17.08 22 12.06Z"></path>
      </svg>
      <span>Facebook</span>
    </a>
  </div>

  <!-- ===== SLIDE NAVIGATION ===== -->
  <div
    class="absolute bottom-28 left-6 md:left-16 lg:left-24 z-20 flex items-center"
    data-animate="fade-up"
    data-animate-trigger="load"
    data-animate-delay="0.35"
    data-animate-duration="0.85"
  >
    <div id="slide-numbers" class="flex gap-1 text-sm font-semibold md:text-base">
      <span class="slide-num active text-white cursor-pointer inline-flex items-baseline gap-1" data-index="0">
        01
        <span class="slide-line block h-px w-8 bg-white opacity-100 transition-all duration-500 ease-in-out"></span>
      </span>
      <span class="slide-num text-white/40 cursor-pointer inline-flex items-baseline gap-1" data-index="1">
        02
        <span class="slide-line block h-px w-1 bg-white/40 opacity-0 transition-all duration-500 ease-in-out"></span>
      </span>
      <span class="slide-num text-white/40 cursor-pointer inline-flex items-baseline gap-1" data-index="2">
        03
        <span class="slide-line block h-px w-1 bg-white/40 opacity-0 transition-all duration-500 ease-in-out"></span>
      </span>
      <span class="slide-num text-white/40 cursor-pointer inline-flex items-baseline gap-1" data-index="3">
        04
        <span class="slide-line block h-px w-1 bg-white/40 opacity-0 transition-all duration-500 ease-in-out"></span>
      </span>
    </div>
  </div>

  <div
    class="absolute bottom-28 right-6 z-20 flex items-center gap-3 md:right-16 lg:right-24"
    data-animate="fade-up"
    data-animate-trigger="load"
    data-animate-delay="0.45"
    data-animate-duration="0.85"
  >
    <button
      type="button"
      class="hero-prev inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/45 bg-white/15 text-white shadow-[0_10px_25px_rgba(15,23,42,0.18)] backdrop-blur-md transition hover:bg-white/25 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
      aria-label="Previous slide"
    >
      <ArrowLeft class="h-4 w-4" aria-hidden="true" />
    </button>
    <button
      type="button"
      class="hero-next inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/45 bg-white/15 text-white shadow-[0_10px_25px_rgba(15,23,42,0.18)] backdrop-blur-md transition hover:bg-white/25 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
      aria-label="Next slide"
    >
      <ArrowRight class="h-4 w-4" aria-hidden="true" />
    </button>
  </div>
</div>

<script>
  import Swiper from 'swiper';
  import { Autoplay, Navigation } from 'swiper/modules';

  const heroSection = document.querySelector('.hero-section');
  const heroSwiper = heroSection?.querySelector('.hero-swiper');
  const heroNext = heroSection?.querySelector('.hero-next');
  const heroPrev = heroSection?.querySelector('.hero-prev');
  const slideNums = heroSection?.querySelectorAll('.slide-num') ?? [];

  if (heroSwiper && heroNext && heroPrev) {
    const swiper = new Swiper(heroSwiper, {
    modules: [Autoplay, Navigation],
    loop: true,
    speed: 800,
    autoplay: {
      delay: 5000,
      disableOnInteraction: false,
    },
    navigation: {
      nextEl: heroNext,
      prevEl: heroPrev,
    },
  });

    const setActive = (idx) => {
      slideNums.forEach((num, i) => {
      const line = num.querySelector('.slide-line');
      if (i === idx) {
        num.classList.remove('text-white/40');
        num.classList.add('text-white');
        if (line) {
          line.classList.remove('opacity-0', 'w-1', 'bg-white/40');
          line.classList.add('opacity-100', 'w-8', 'bg-white');
        }
      } else {
        num.classList.remove('text-white');
        num.classList.add('text-white/40');
        if (line) {
          line.classList.remove('opacity-100', 'w-8', 'bg-white');
          line.classList.add('opacity-0', 'w-1', 'bg-white/40');
        }
      }
    });
    };

    setActive(swiper.realIndex);

    swiper.on('slideChange', () => {
      setActive(swiper.realIndex);
    });

    slideNums.forEach((num) => {
      num.addEventListener('click', () => {
        const idx = parseInt(num.dataset.index ?? '0', 10);
        swiper.slideToLoop(idx);
      });
    });
  }
</script>

<style>
  .vertical-text {
    writing-mode: vertical-rl;
    text-orientation: mixed;
  }
  .social-icon {
    rotate: 90deg;
  }
  .slide-num {
    cursor: pointer;
    transition: color 0.4s;
    position: relative;
  }
</style>
