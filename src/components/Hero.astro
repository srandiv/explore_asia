---
import sigiriyaImg from '../assets/images/ hero/chathura-indika-laj-xlhp6rs-unsplash.webp';
import galleImg from '../assets/images/ hero/malith-d-karunarathne--pw-saa99lw-unsplash.webp';
import elephantImg from '../assets/images/ hero/paul-kapischka-43fxbr3mqoy-unsplash.webp';
import adamsPeakImg from '../assets/images/ hero/yves-alarie-yagheetusk4-unsplash.webp';

const slides = [
  {
    image: sigiriyaImg,
    title: 'SIGIRIYA',
    subtitle: 'Sigiriya is one of the most valuable historical monuments of Sri Lanka.',
  },
  {
    image: galleImg,
    title: 'GALLE FORT',
    subtitle: 'Wander through the charming colonial streets of the UNESCO-listed Galle Fort.',
  },
  {
    image: elephantImg,
    title: 'ELEPHANT SAFARI',
    subtitle: 'Witness majestic elephants roaming freely in their natural habitat.',
  },
  {
    image: adamsPeakImg,
    title: "ADAM'S PEAK",
    subtitle: 'Experience the breathtaking night ascent to the sacred mountain summit.',
  },
];
---

<div id="hero-wrapper" class="relative h-screen w-full overflow-hidden">
  <!-- ===== HEADER ===== -->
  <header class="absolute top-0 left-0 z-50 w-full bg-gradient-to-b from-black/60 to-transparent">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
      <!-- Logo -->
      <a href="/" class="text-lg font-bold tracking-wide text-white">
        Sri Lanka <span class="text-brand-gold">Classy</span> Tours
      </a>

      <!-- Navigation -->
      <nav class="hidden items-center gap-6 text-xs font-semibold tracking-wider text-white lg:flex">
        <a href="/" class="hover:text-brand-gold transition-colors">HOME</a>
        <a href="/tours" class="hover:text-brand-gold transition-colors">TOURS</a>
        <a href="/offers" class="hover:text-brand-gold transition-colors">OFFERS</a>
        <a href="/excursions" class="hover:text-brand-gold transition-colors">EXCURSIONS</a>
        <a href="/destinations" class="hover:text-brand-gold transition-colors">DESTINATION</a>
        <a href="/hotels" class="hover:text-brand-gold transition-colors">HOTELS</a>
        <a href="/maldives" class="hover:text-brand-gold transition-colors">MALDIVES</a>
        <a href="/contact" class="hover:text-brand-gold transition-colors">CONTACT US</a>
      </nav>

      <!-- Header icons + Hamburger -->
      <div class="flex items-center gap-4 text-white">
        <a href="tel:+940000000000" class="hidden md:block hover:text-brand-gold transition-colors" title="Call">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </a>
        <a href="mailto:info@classytours.com" class="hidden md:block hover:text-brand-gold transition-colors" title="Email">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </a>
        <a href="/" class="hidden md:block hover:text-brand-gold transition-colors" title="Language">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </a>
        <button class="text-white lg:hidden" title="Menu" id="menu-toggle">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </header>

  <!-- ===== SWIPER SLIDES ===== -->
  <div class="swiper hero-swiper h-full w-full">
    <div class="swiper-wrapper">
      {
        slides.map((slide, i) => (
          <div class="swiper-slide relative">
            <img
              src={slide.image.src}
              alt={slide.title}
              class="absolute inset-0 h-full w-full object-cover"
              fetchpriority={i === 0 ? 'high' : 'lazy'}
            />
            <!-- Overlay -->
            <div class="absolute inset-0 bg-black/40"></div>

            <!-- Slide content -->
            <div class="absolute bottom-48 left-6 z-10 md:left-16 lg:left-24 lg:bottom-56">
              <h2 class="text-5xl font-bold tracking-wider text-white md:text-7xl lg:text-8xl">
                {slide.title}
              </h2>
              <p class="mt-4 max-w-lg text-sm leading-relaxed text-white/90 md:text-base lg:text-lg">
                {slide.subtitle}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <!-- ===== SOCIAL MEDIA SIDEBAR (right edge) ===== -->
  <div class="absolute right-0 top-1/2 z-20 hidden -translate-y-1/2 flex-col items-center gap-8 md:flex">
    <a href="https://instagram.com" target="_blank" rel="noopener" class="vertical-text text-xs tracking-[0.3em] text-white/70 hover:text-white transition-colors" style="writing-mode: vertical-rl;">
      INSTAGRAM
    </a>
    <a href="https://twitter.com" target="_blank" rel="noopener" class="vertical-text text-xs tracking-[0.3em] text-white/70 hover:text-white transition-colors" style="writing-mode: vertical-rl;">
      TWITTER
    </a>
    <a href="https://facebook.com" target="_blank" rel="noopener" class="vertical-text text-xs tracking-[0.3em] text-white/70 hover:text-white transition-colors" style="writing-mode: vertical-rl;">
      FACEBOOK
    </a>
  </div>

  <!-- ===== SLIDE NAVIGATION (bottom-left) ===== -->
  <div class="absolute bottom-28 left-6 z-20 flex items-center md:left-16 lg:left-24">
    <div id="slide-numbers" class="flex gap-1 text-sm font-semibold md:text-base">
      <span class="slide-num active text-white cursor-pointer inline-flex items-baseline gap-1" data-index="0">
        01
        <span class="slide-line block h-[3px] w-5 bg-white rounded-sm opacity-100 transition-all duration-500 ease-in-out"></span>
      </span>
      <span class="slide-num text-white/40 cursor-pointer inline-flex items-baseline gap-1" data-index="1">
        02
        <span class="slide-line block h-[3px] w-1 bg-white/40 rounded-sm opacity-0 transition-all duration-500 ease-in-out"></span>
      </span>
      <span class="slide-num text-white/40 cursor-pointer inline-flex items-baseline gap-1" data-index="2">
        03
        <span class="slide-line block h-[3px] w-1 bg-white/40 rounded-sm opacity-0 transition-all duration-500 ease-in-out"></span>
      </span>
      <span class="slide-num text-white/40 cursor-pointer inline-flex items-baseline gap-1" data-index="3">
        04
        <span class="slide-line block h-[3px] w-1 bg-white/40 rounded-sm opacity-0 transition-all duration-500 ease-in-out"></span>
      </span>
    </div>
  </div>

  <!-- ===== INQUIRY FORM BAR (bottom) ===== -->
  <div class="absolute bottom-0 left-0 z-20 w-full bg-black/60 backdrop-blur-sm">
    <div class="mx-auto flex max-w-7xl flex-col items-center gap-4 px-6 py-4 md:flex-row md:py-3 lg:px-8">
      <span class="text-sm font-semibold tracking-wider text-white whitespace-nowrap md:text-xs lg:text-sm">
        PLAN YOU DREAM TOUR WITH CLASSY TOURS
      </span>
      <form class="flex w-full flex-wrap items-center gap-3 md:flex-1 md:flex-nowrap md:gap-2">
        <input type="text" placeholder="Your Name" class="min-w-0 flex-1 bg-white/10 border border-white/20 px-3 py-2 text-sm text-white placeholder-white/50 outline-none focus:border-brand-gold transition-colors" />
        <input type="email" placeholder="Your Email" class="min-w-0 flex-1 bg-white/10 border border-white/20 px-3 py-2 text-sm text-white placeholder-white/50 outline-none focus:border-brand-gold transition-colors" />
        <input type="tel" placeholder="Contact Number" class="min-w-0 flex-1 bg-white/10 border border-white/20 px-3 py-2 text-sm text-white placeholder-white/50 outline-none focus:border-brand-gold transition-colors" />
        <input type="text" placeholder="Country" class="min-w-0 flex-1 bg-white/10 border border-white/20 px-3 py-2 text-sm text-white placeholder-white/50 outline-none focus:border-brand-gold transition-colors" />
        <button type="submit" class="bg-brand-blue hover:bg-brand-blue/80 cursor-pointer px-6 py-2 text-sm font-semibold text-white transition-colors whitespace-nowrap">
          INQUIRE
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  import Swiper from 'swiper';

  const swiper = new Swiper('.hero-swiper', {
    loop: true,
    speed: 800,
    autoplay: {
      delay: 5000,
      disableOnInteraction: false,
    },
  });

  const slideNums = document.querySelectorAll('.slide-num');

  function setActive(idx) {
    slideNums.forEach((num, i) => {
      const line = num.querySelector('.slide-line');
      if (i === idx) {
        num.classList.remove('text-white/40');
        num.classList.add('text-white');
        if (line) {
          line.classList.remove('opacity-0', 'w-1', 'bg-white/40');
          line.classList.add('opacity-100', 'w-5', 'bg-white');
        }
      } else {
        num.classList.remove('text-white');
        num.classList.add('text-white/40');
        if (line) {
          line.classList.remove('opacity-100', 'w-5', 'bg-white');
          line.classList.add('opacity-0', 'w-1', 'bg-white/40');
        }
      }
    });
  }

  // Set initial active after swiper fully initializes
  swiper.on('init', () => {
    setActive(swiper.realIndex);
  });

  swiper.on('slideChange', () => {
    setActive(swiper.realIndex);
  });

  // Click to navigate
  slideNums.forEach((num) => {
    num.addEventListener('click', () => {
      const idx = parseInt(num.dataset.index, 10);
      swiper.slideToLoop(idx);
    });
  });
</script>

<style>
  .vertical-text {
    writing-mode: vertical-rl;
    text-orientation: mixed;
  }
  .slide-num {
    cursor: pointer;
    transition: color 0.4s;
    position: relative;
  }
</style>
