---
import { ArrowRight, ArrowUpRight } from "@lucide/astro";
---

<section class="welcome-section bg-white">
  <div
    class="section-container grid grid-cols-1 gap-10 lg:grid-cols-2 lg:items-center"
  >
    <div class="intro-copy" data-animate="fade-right">
      <div class="section-heading" data-align="left">
        <p>Welcome to Explore Asia Travels Pvt Ltd</p>
        <h2 id="holiday-intro-title">Discover Asia, Your Way</h2>
        <p>
          Personalized travel experiences across Sri Lanka and Asia with
          professional planning, dependable service, and exceptional value.
        </p>
      </div>

      <div class="intro-body">
        <p data-animate="fade-up" data-animate-delay="0.08">
          At Explore Asia Travels Pvt Ltd, we create unforgettable travel
          experiences across Sri Lanka and Asia with personalized service,
          professional planning, and exceptional value. As a trusted Destination
          Management Company, we deliver seamless journeys for travel partners
          and travelers from around the world.
        </p>

        <p data-animate="fade-up" data-animate-delay="0.16">
          Whether you are a travel partner looking for a dependable DMC or a
          traveler seeking authentic experiences, Explore Asia Travels Pvt Ltd is
          ready to make your journey extraordinary.
        </p>
      </div>

      <a class="site-button" href="/about" data-animate="fade-up" data-animate-delay="0.24">
        <span>View More</span>
        <span class="site-button-icon" aria-hidden="true">
          <ArrowUpRight class="site-button-icon-angle stroke-[3]" />
          <ArrowRight class="site-button-icon-straight stroke-[3]" />
        </span>
      </a>
    </div>

    <div data-animate="fade-left" data-animate-delay="0.12">
      <div
        class="mask-contain mask-no-repeat mask-[url(../assets/images/masks/brush-stock-mask.png)] h-[23rem] w-full bg-[url(../assets/images/sri-lanka-unsplash-sigiriya.jpg)] bg-center bg-cover sm:h-[32rem] lg:h-[38rem]"
      >
      </div>
    </div>
  </div>
</section>
