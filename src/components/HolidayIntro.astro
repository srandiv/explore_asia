---
import { ArrowRight } from "@lucide/astro";
---

<section
  class="site-section welcome-section bg-white"
>
  <div class="section-container grid grid-cols-1 gap-10 lg:grid-cols-2 lg:items-center">
    <div class="intro-copy">
      <div class="section-heading" data-align="left">
        <p>Welcome to Explore Asia</p>
        <h2 id="holiday-intro-title">Holidays with Lanka Classy Tours</h2>
        <p>Customized Sri Lanka holidays planned around your pace, budget, comfort, and travel style.</p>
      </div>

      <div class="intro-body">
        <p>
          Lanka Classy Tours creates custom Sri Lanka holidays with local guidance,
          comfortable stays, and flexible routes built around the way you like to travel.
        </p>

        <p>
          Share your dates, group size, budget, and favorite places. We will shape a
          refreshing island journey that feels easy from arrival to departure.
        </p>
      </div>

      <a class="text-link" href="/about">
        <span>View More</span>
        <ArrowRight class="h-[17px] w-[17px] stroke-[3]" aria-hidden="true" />
      </a>
    </div>

    <div>
      <div
        class="mask-contain mask-no-repeat mask-[url(../assets/images/masks/brush-stock-mask.png)] h-[24rem] w-full bg-[url(../assets/images/sri-lanka-unsplash-sigiriya.jpg)] bg-center bg-cover lg:h-[38rem]"
      >
      </div>
    </div>
  </div>
</section>
