---
import { Globe2 } from "@lucide/astro";

interface Props {
  variant?: "desktop" | "mobile";
  class?: string;
}

const { variant = "desktop", class: className = "" } = Astro.props;

const languages = [
  {
    code: "en",
    label: "English",
    flag: "/flags/united-kingdom.svg",
  },
  {
    code: "fr",
    label: "French",
    flag: "/flags/france.svg",
  },
  {
    code: "it",
    label: "Italian",
    flag: "/flags/italy.svg",
  },
  {
    code: "es",
    label: "Spanish",
    flag: "/flags/spain.svg",
  },
  {
    code: "de",
    label: "German",
    flag: "/flags/germany.svg",
  },
  {
    code: "hi",
    label: "Hindi",
    flag: "/flags/india.svg",
  },
  {
    code: "ar",
    label: "Arabic",
    flag: "/flags/saudi-arabia.svg",
  },
];
---

<details
  class:list={["language-selector notranslate", className]}
  data-variant={variant}
  translate="no"
>
  <summary class="language-selector-trigger" aria-label="Choose language">
    <Globe2 class="language-selector-globe h-4 w-4" aria-hidden="true" />
    <img
      class="language-selector-current-flag"
      src="/flags/united-kingdom.svg"
      alt=""
      loading="lazy"
      aria-hidden="true"
    />
  </summary>

  <div class="language-selector-menu" role="listbox" aria-label="Choose language">
    {
      languages.map((language) => (
        <button
          type="button"
          class="language-selector-option"
          data-language-code={language.code}
          role="option"
        >
          <img src={language.flag} alt="" loading="lazy" />
          <span>{language.label}</span>
        </button>
      ))
    }
  </div>

</details>

<script>
  const defaultLanguage = "en";
  const languageStorageKey = "exploreAsiaLanguage";
  const languages = {
    en: {
      label: "English",
      flag: "/flags/united-kingdom.svg",
    },
    fr: {
      label: "French",
      flag: "/flags/france.svg",
    },
    it: {
      label: "Italian",
      flag: "/flags/italy.svg",
    },
    es: {
      label: "Spanish",
      flag: "/flags/spain.svg",
    },
    de: {
      label: "German",
      flag: "/flags/germany.svg",
    },
    hi: {
      label: "Hindi",
      flag: "/flags/india.svg",
    },
    ar: {
      label: "Arabic",
      flag: "/flags/saudi-arabia.svg",
    },
  };

  const closeOtherSelectors = (currentSelector: HTMLDetailsElement) => {
    document
      .querySelectorAll<HTMLDetailsElement>(".language-selector[open]")
      .forEach((selector) => {
        if (selector !== currentSelector) {
          selector.removeAttribute("open");
        }
      });
  };

  const getLanguageFromCookie = () => {
    const match = document.cookie.match("(^|;) ?googtrans=([^;]*)(;|$)");
    const languageCode = match?.[2]?.split("/")?.[2];

    return languageCode && languageCode in languages ? languageCode : null;
  };

  const getStoredLanguage = () => {
    const languageCode = window.localStorage.getItem(languageStorageKey);

    return languageCode && languageCode in languages ? languageCode : null;
  };

  const storeLanguage = (languageCode: string) => {
    window.localStorage.setItem(languageStorageKey, languageCode);
  };

  const wakeGTranslate = () => {
    const engineId = "google_translate_element2";
    let engine = document.querySelector<HTMLElement>(`#${engineId}`);

    if (!engine) {
      engine = document.createElement("div");
      engine.id = engineId;
      engine.className = "language-translate-engine";
      document.body.append(engine);
    }

    window.googleTranslateElementInit2 = () => {
      const googleTranslate = (window as any).google?.translate;

      if (!googleTranslate || document.querySelector(".goog-te-combo")) {
        return;
      }

      new googleTranslate.TranslateElement(
        {
          pageLanguage: defaultLanguage,
          includedLanguages: Object.keys(languages).join(","),
          autoDisplay: false,
        },
        engineId,
      );
    };

    if ((window as any).google?.translate?.TranslateElement) {
      window.googleTranslateElementInit2();
      return;
    }

    if (!document.querySelector('script[data-google-translate-element="true"]')) {
      const script = document.createElement("script");
      script.src =
        "https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit2";
      script.defer = true;
      script.dataset.googleTranslateElement = "true";
      document.body.append(script);
    }
  };

  const fireChange = (element: HTMLSelectElement) => {
    const event = document.createEvent("HTMLEvents");
    event.initEvent("change", true, true);
    element.dispatchEvent(event);
  };

  const setActiveLanguage = (languageCode: string | null) => {
    const language =
      languageCode && languageCode in languages
        ? languages[languageCode as keyof typeof languages]
        : null;

    document.querySelectorAll<HTMLDetailsElement>(".language-selector").forEach((selector) => {
      const flag = selector.querySelector<HTMLImageElement>(
        ".language-selector-current-flag",
      );
      const trigger = selector.querySelector<HTMLElement>(
        ".language-selector-trigger",
      );

      selector
        .querySelectorAll<HTMLButtonElement>(".language-selector-option")
        .forEach((option) => {
          option.setAttribute(
            "aria-selected",
            String(option.dataset.languageCode === languageCode),
          );
        });

      if (!language || !flag || !trigger) {
        selector.removeAttribute("data-active-language");
        return;
      }

      selector.dataset.activeLanguage = languageCode;
      flag.src = language.flag;
      flag.alt = `${language.label} selected`;
      trigger.setAttribute("aria-label", `Choose language, current ${language.label}`);
      trigger.setAttribute("title", language.label);
    });
  };

  const translateTo = (languageCode: string, attempt = 0) => {
    wakeGTranslate();

    const translateSelect =
      document.querySelector<HTMLSelectElement>(".goog-te-combo");

    const hasLanguageOption = Boolean(
      translateSelect?.querySelector(`option[value="${languageCode}"]`),
    );

    if (!translateSelect || !hasLanguageOption) {
      if (attempt < 60) {
        window.setTimeout(() => translateTo(languageCode, attempt + 1), 250);
      }

      return;
    }

    setActiveLanguage(languageCode);
    storeLanguage(languageCode);

    translateSelect.value = languageCode;
    fireChange(translateSelect);
    fireChange(translateSelect);
  };

  document.querySelectorAll<HTMLDetailsElement>(".language-selector").forEach((selector) => {
    selector.addEventListener("toggle", () => {
      if (selector.open) {
        closeOtherSelectors(selector);
      }
    });
  });

  document.querySelectorAll<HTMLButtonElement>(".language-selector-option").forEach((button) => {
    button.addEventListener("click", () => {
      const languageCode = button.dataset.languageCode;

      if (!languageCode) {
        return;
      }

      translateTo(languageCode);
      setActiveLanguage(languageCode);
      storeLanguage(languageCode);
      button.closest(".language-selector")?.removeAttribute("open");
    });
  });

  document.addEventListener("click", (event) => {
    const target = event.target;

    if (!(target instanceof Element)) {
      return;
    }

    document
      .querySelectorAll<HTMLDetailsElement>(".language-selector[open]")
      .forEach((selector) => {
        if (!selector.contains(target)) {
          selector.removeAttribute("open");
        }
      });
  });

  const activeLanguage = getStoredLanguage() ?? getLanguageFromCookie();
  setActiveLanguage(activeLanguage);

  if (activeLanguage && activeLanguage !== defaultLanguage) {
    window.setTimeout(() => translateTo(activeLanguage), 300);
  }
</script>

<style is:global>
  .language-selector {
    position: relative;
    width: fit-content;
  }

  .language-selector-trigger {
    display: grid;
    width: 2.75rem;
    height: 2.75rem;
    place-items: center;
    color: #ffffff;
    cursor: pointer;
    list-style: none;
    border: 1px solid rgba(255, 255, 255, 0.62);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    box-shadow: 0 12px 28px rgba(15, 23, 42, 0.2);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .language-selector-trigger::-webkit-details-marker {
    display: none;
  }

  .language-selector-trigger:hover {
    color: #0d1b2a;
    border-color: #ffffff;
    background: #ffffff;
    transform: translateY(-1px);
  }

  .language-selector-trigger:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 2px;
  }

  .language-selector-current-flag {
    display: none;
    width: 1.35rem;
    height: 1.35rem;
    object-fit: cover;
    border-radius: 999px;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.5);
  }

  .language-selector[data-active-language] .language-selector-globe {
    display: none;
  }

  .language-selector[data-active-language] .language-selector-current-flag {
    display: block;
  }

  .language-selector-menu {
    position: absolute;
    top: calc(100% + 0.75rem);
    right: 0;
    z-index: 60;
    display: grid;
    min-width: 11.75rem;
    gap: 0.25rem;
    padding: 0.45rem;
    visibility: hidden;
    background: rgba(255, 255, 255, 0.96);
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: 8px;
    box-shadow: 0 24px 70px rgba(15, 23, 42, 0.22);
    opacity: 0;
    transform: translateY(0.5rem);
    -webkit-backdrop-filter: blur(22px) saturate(140%);
    backdrop-filter: blur(22px) saturate(140%);
    transition:
      opacity 180ms ease,
      transform 180ms ease,
      visibility 180ms ease;
  }

  .language-selector[open] .language-selector-menu {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
  }

  .language-selector-option {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    width: 100%;
    padding: 0.72rem 0.8rem;
    color: #334155;
    font-family: "Instrument Sans", Inter, Roboto, Arial, sans-serif;
    font-size: 0.88rem;
    font-weight: 700;
    text-align: left;
    cursor: pointer;
    background: transparent;
    border: 0;
    border-radius: 6px;
    transition:
      background-color 160ms ease,
      color 160ms ease;
  }

  .language-selector-option:hover,
  .language-selector-option:focus-visible {
    color: #1b9c50;
    background: rgba(27, 156, 80, 0.1);
    outline: none;
  }

  .language-selector-option img {
    width: 1.35rem;
    height: 1.35rem;
    object-fit: cover;
    border-radius: 999px;
    box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.12);
  }

  .language-translate-engine,
  iframe.skiptranslate,
  .skiptranslate {
    display: none !important;
  }

  body {
    top: 0 !important;
  }

  .language-selector[data-variant="mobile"] {
    width: fit-content;
  }

  .language-selector[data-variant="mobile"] .language-selector-trigger {
    color: #0f172a;
    border-color: rgb(203, 213, 225);
    background: #ffffff;
    box-shadow: none;
  }

  .language-selector[data-variant="mobile"] .language-selector-trigger:hover {
    color: #ffffff;
    border-color: #1b9c50;
    background: #1b9c50;
  }

  .language-selector[data-variant="mobile"] .language-selector-trigger:focus-visible {
    outline-color: #1b9c50;
  }

  .language-selector[data-variant="mobile"] .language-selector-menu {
    right: auto;
    left: 50%;
    min-width: min(11.75rem, calc(100vw - 2rem));
    transform: translate(-50%, 0.5rem);
  }

  .language-selector[data-variant="mobile"][open] .language-selector-menu {
    transform: translate(-50%, 0);
  }
</style>
