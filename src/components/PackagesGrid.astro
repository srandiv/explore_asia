---
import { ArrowRight, ArrowUpRight, ChevronLeft, ChevronRight } from "@lucide/astro";
import { getCollection } from "astro:content";

const packages = (await getCollection("packages")).sort((a, b) => a.data.order - b.data.order);
---

<section class="packages-section site-section relative overflow-hidden bg-white">
  <div class="section-container">
    <div class="section-heading" data-animate="fade-up">
      <p>Tour Packages</p>
      <h2>
        Explore Sri Lanka Your Way
      </h2>
      <p>
        Handpicked private journeys across beaches, wildlife, culture, hill country, and hidden local favorites.
      </p>
    </div>

    <div class="package-showcase-carousel" data-animate="fade-up" data-animate-delay="0.12">
      <button type="button" class="package-showcase-control standard-packages-prev" aria-label="Previous tour package">
        <ChevronLeft aria-hidden="true" />
      </button>

      <div class="swiper package-showcase-swiper standard-packages-swiper">
        <div class="swiper-wrapper">
          {
            packages.map((pkg) => (
              <div class="swiper-slide">
                <a href={`/packages/${pkg.id}`} class="package-showcase-card">
                  <article>
                    <div class="package-showcase-media">
                      <img src={pkg.data.image} alt={pkg.data.imageAlt} loading="lazy" />
                    </div>

                    <div class="package-showcase-content">
                      <div>
                        <p data-role="duration">{pkg.data.duration ?? "Private Sri Lanka Tour"}</p>
                        <h3>{pkg.data.title}</h3>
                      </div>

                      <div class="package-showcase-footer">
                        <div>
                          {pkg.data.price?.amount && <strong>{pkg.data.price.amount}</strong>}
                          <span data-role="note">{pkg.data.price?.note ?? "View package details"}</span>
                        </div>
                        <span class="package-showcase-arrow" aria-hidden="true">
                          <ArrowRight />
                        </span>
                      </div>
                    </div>
                  </article>
                </a>
              </div>
            ))
          }
        </div>
      </div>

      <button type="button" class="package-showcase-control standard-packages-next" aria-label="Next tour package">
        <ChevronRight aria-hidden="true" />
      </button>
    </div>

    <div class="mt-8 text-center" data-animate="fade-up" data-animate-delay="0.24">
      <a href="/packages" class="site-button">
        View More
        <span class="site-button-icon" aria-hidden="true">
          <ArrowUpRight class="site-button-icon-angle stroke-[3]" />
          <ArrowRight class="site-button-icon-straight stroke-[3]" />
        </span>
      </a>
    </div>
  </div>
</section>

<script>
  import Swiper from "swiper";
  import { Autoplay, Navigation } from "swiper/modules";

  const packagesSection = document.querySelector(".packages-section");
  const packagesSwiper = packagesSection?.querySelector(".standard-packages-swiper");
  const packagesNext = packagesSection?.querySelector(".standard-packages-next");
  const packagesPrev = packagesSection?.querySelector(".standard-packages-prev");

  if (packagesSwiper && packagesNext && packagesPrev) {
    new Swiper(packagesSwiper, {
      modules: [Autoplay, Navigation],
      loop: true,
      speed: 750,
      spaceBetween: 20,
      autoplay: {
        delay: 3400,
        disableOnInteraction: false,
        pauseOnMouseEnter: true,
      },
      navigation: {
        nextEl: packagesNext,
        prevEl: packagesPrev,
      },
      breakpoints: {
        0: {
          slidesPerView: 1.05,
        },
        640: {
          slidesPerView: 1.35,
        },
        768: {
          slidesPerView: 2,
        },
        1180: {
          slidesPerView: 3,
        },
      },
    });
  }
</script>
