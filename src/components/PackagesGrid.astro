---
import { getCollection } from "astro:content";

const packages = (await getCollection("packages")).sort((a, b) => a.data.order - b.data.order);
const featuredPackage = packages[0];
const gridPackages = packages.slice(1, 5);
---

<section class="packages-section relative overflow-hidden bg-white py-16 sm:py-20 lg:py-24">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-14 bg-[radial-gradient(circle_at_10%_20%,rgba(218,236,236,0.9),rgba(255,255,255,0)_45%),radial-gradient(circle_at_50%_0%,rgba(218,236,236,0.7),rgba(255,255,255,0)_42%),radial-gradient(circle_at_90%_18%,rgba(218,236,236,0.75),rgba(255,255,255,0)_45%)] opacity-80"></div>

  <div class="relative mx-auto max-w-7xl px-6 md:px-16 lg:px-24">
    <div class="mb-8 max-w-3xl space-y-2">
      <p class="text-[1.8rem] font-light tracking-tight text-slate-600 sm:text-[2.15rem]">Highlights of</p>
      <h2 class="text-[2.25rem] font-semibold tracking-tight text-slate-700 sm:text-[2.85rem] lg:text-[3.15rem]">
        Our Tour Packages
      </h2>
    </div>

    <div class="grid gap-3 lg:grid-cols-[1.22fr_1fr]">
      <a href={`/packages/${featuredPackage.id}`} class="group block min-h-[520px] lg:min-h-[560px]">
        <article class="relative h-full overflow-hidden bg-slate-200 shadow-[0_18px_40px_rgba(15,23,42,0.08)]">
          <img
            src={featuredPackage.data.image}
            alt={featuredPackage.data.imageAlt}
            class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/20 to-slate-950/10"></div>
          <div class="absolute inset-x-0 bottom-0 p-6 text-white sm:p-7">
            <h3 class="text-2xl font-semibold tracking-tight sm:text-[1.9rem]">{featuredPackage.data.title}</h3>
            <p class="mt-3 max-w-xl text-sm leading-6 text-white/85 sm:text-base">
              {featuredPackage.data.description}
            </p>
          </div>
        </article>
      </a>

      <div class="grid gap-3 sm:grid-cols-2 sm:grid-rows-2 lg:h-[560px]">
        {
          gridPackages.map((pkg) => (
            <a href={`/packages/${pkg.id}`} class="group block min-h-[245px]">
              <article class="relative h-full overflow-hidden bg-slate-200 shadow-[0_18px_40px_rgba(15,23,42,0.08)]">
                <img
                  src={pkg.data.image}
                  alt={pkg.data.imageAlt}
                  class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/30 to-slate-950/10"></div>
                <div class="absolute inset-x-0 bottom-0 p-4 text-white">
                  <h3 class="text-xl font-semibold tracking-tight sm:text-[1.35rem]">{pkg.data.title}</h3>
                  <p class="mt-1 line-clamp-2 max-w-[22rem] text-sm leading-6 text-white/85">
                    {pkg.data.description}
                  </p>
                </div>
              </article>
            </a>
          ))
        }
      </div>
    </div>

    <div class="mt-8 text-center">
      <a href="/packages" class="inline-flex items-center gap-2 text-base font-semibold text-brand-blue transition-colors hover:text-slate-800">
        View More
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
