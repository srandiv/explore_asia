---
import { ArrowRight, ArrowUpRight } from "@lucide/astro";
import { getCollection } from "astro:content";

const packages = (await getCollection("packages")).sort((a, b) => a.data.order - b.data.order);
const featuredPackage = packages[0];
const gridPackages = packages.slice(1, 5);
---

<section class="packages-section site-section relative overflow-hidden bg-white">
  <div class="section-container">
    <div class="section-heading" data-animate="fade-up">
      <p>Tour Packages</p>
      <h2>
        Our Tour Packages
      </h2>
      <p>
        Explore handpicked Sri Lanka journeys with flexible routes, local guides, and room to tailor each day.
      </p>
    </div>

    <div class="mt-10 grid gap-3 lg:grid-cols-[1.22fr_1fr]">
      <a href={`/packages/${featuredPackage.id}`} class="group block min-h-[520px] lg:min-h-[560px]" data-animate="fade-right" data-animate-delay="0.12">
        <article class="relative h-full overflow-hidden bg-slate-200 shadow-[0_18px_40px_rgba(15,23,42,0.08)]">
          <img
            src={featuredPackage.data.image}
            alt={featuredPackage.data.imageAlt}
            class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/20 to-slate-950/10"></div>
          <div class="package-card-copy" data-featured="true">
            <h3>{featuredPackage.data.title}</h3>
            <p>
              {featuredPackage.data.description}
            </p>
          </div>
        </article>
      </a>

      <div class="grid gap-3 sm:grid-cols-2 sm:grid-rows-2 lg:h-[560px]">
        {
          gridPackages.map((pkg, index) => (
            <a
              href={`/packages/${pkg.id}`}
              class="group block min-h-[245px]"
              data-animate="fade-up"
              data-animate-delay={`${0.18 + index * 0.08}`}
            >
              <article class="relative h-full overflow-hidden bg-slate-200 shadow-[0_18px_40px_rgba(15,23,42,0.08)]">
                <img
                  src={pkg.data.image}
                  alt={pkg.data.imageAlt}
                  class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/30 to-slate-950/10"></div>
                <div class="package-card-copy" data-compact="true">
                  <h3>{pkg.data.title}</h3>
                  <p>
                    {pkg.data.description}
                  </p>
                </div>
              </article>
            </a>
          ))
        }
      </div>
    </div>

    <div class="mt-8 text-center" data-animate="fade-up" data-animate-delay="0.24">
      <a href="/packages" class="site-button">
        View More
        <span class="site-button-icon" aria-hidden="true">
          <ArrowUpRight class="site-button-icon-angle stroke-[3]" />
          <ArrowRight class="site-button-icon-straight stroke-[3]" />
        </span>
      </a>
    </div>
  </div>
</section>
