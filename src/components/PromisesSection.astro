---
import {
  BadgeCheck,
  Bus,
  Headphones,
  Map,
  ShieldCheck,
  Sparkles,
} from "@lucide/astro";

const promises = [
  {
    title: "Professional Destination Management",
    text: "Every program is coordinated with clear planning, local insight, and dependable on-ground support.",
    icon: Map,
  },
  {
    title: "Personalized Travel Experiences",
    text: "Tours can be shaped around each market, guest profile, budget, pace, and travel style.",
    icon: Sparkles,
  },
  {
    title: "Luxury & Budget-Friendly Solutions",
    text: "We balance comfort and value so partners can offer the right experience at the right price.",
    icon: BadgeCheck,
  },
  {
    title: "Reliable Transport & Expert Guides",
    text: "Our transport network and professional guides help each day run smoothly from start to finish.",
    icon: Bus,
  },
  {
    title: "24/7 Customer Support",
    text: "Guests and partners have responsive help whenever plans shift or support is needed.",
    icon: Headphones,
  },
  {
    title: "Memorable Journeys Across Sri Lanka & Asia",
    text: "We focus on comfort, care, and meaningful moments that guests remember after they return home.",
    icon: ShieldCheck,
  },
];
---

<section class="promises-section site-section bg-white">
  <div class="section-container">
    <div class="section-heading" data-animate="fade-up">
      <p>Our Promise</p>
      <h2>Explore beyond expectations</h2>
      <p>
        Your comfort, happiness, and satisfaction are always our priority. We
        manage each detail with professionalism, flexibility, and care.
      </p>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {
        promises.map((item, index) => {
          const Icon = item.icon;

          return (
            <article
              class="promise-card h-full rounded-lg border border-brand-secondary/20 bg-white p-6 shadow-[0_18px_42px_rgba(27,156,80,0.08)] transition duration-300 hover:-translate-y-1 hover:border-brand-secondary/45 hover:shadow-[0_22px_50px_rgba(27,156,80,0.14)]"
              data-animate="fade-up"
              data-animate-delay={Math.min(index, 5) * 0.06}
            >
              <span class="promise-icon grid h-12 w-12 place-items-center rounded-lg bg-brand-secondary text-white shadow-[0_14px_28px_rgba(27,156,80,0.24)]">
                <Icon class="h-6 w-6" aria-hidden="true" />
              </span>
              <h3 class="mt-5 text-2xl leading-tight text-slate-900">
                {item.title}
              </h3>
              <p class="mt-3 text-base leading-7 text-slate-600">{item.text}</p>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .promise-card {
    position: relative;
    overflow: hidden;
  }

  .promise-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 4px;
    background: linear-gradient(90deg, rgba(27, 156, 80, 0.4), #1b9c50);
    opacity: 1;
    transition: opacity 300ms ease;
  }

  .promise-card:hover::before {
    opacity: 1;
  }

  .promise-icon {
    transition:
      background-color 300ms ease,
      color 300ms ease;
  }

  .promise-card:hover .promise-icon {
    background-color: #157f43;
    color: #ffffff;
  }
</style>
