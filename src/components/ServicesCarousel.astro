---
import { ChevronLeft, ChevronRight } from "@lucide/astro";
import { getCollection } from "astro:content";

const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order,
);
const servicesBackground =
  "https://images.unsplash.com/photo-1585171095587-208afbf98724?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D";
---

<section
  class="services-section site-section relative overflow-hidden bg-brand-primary"
>
  <img
    src={servicesBackground}
    alt=""
    class="absolute inset-0 h-full w-full object-cover"
    loading="lazy"
    decoding="async"
    aria-hidden="true"
  />
  <div class="absolute inset-0 bg-slate-950/28"></div>
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.34),rgba(255,255,255,0)_34%),linear-gradient(180deg,rgba(255,255,255,0.16)_0%,rgba(15,23,42,0.08)_42%,rgba(15,23,42,0.34)_100%)]"
  >
  </div>

  <div class="section-container relative z-10">
    <div class="section-heading" data-theme="dark" data-animate="fade-up">
      <p>Our Services</p>
      <h2>Everything you need for a smooth Sri Lanka trip</h2>
      <p>
        Choose the service you need and build the trip around it. The carousel
        below can highlight hotels, transport, sightseeing, food, and more.
      </p>
    </div>

    <div class="relative mt-8" data-animate="fade-up" data-animate-delay="0.12">
      <button
        type="button"
        class="services-prev absolute left-0 top-1/2 z-20 inline-flex h-12 w-12 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full border border-white/50 bg-white/20 text-white shadow-[0_10px_25px_rgba(15,23,42,0.2)] backdrop-blur-md transition hover:bg-white/30 sm:h-14 sm:w-14"
        aria-label="Previous service"
      >
        <ChevronLeft class="h-5 w-5" aria-hidden="true" />
      </button>

      <button
        type="button"
        class="services-next absolute right-0 top-1/2 z-20 inline-flex h-12 w-12 translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full border border-white/50 bg-white/20 text-white shadow-[0_10px_25px_rgba(15,23,42,0.2)] backdrop-blur-md transition hover:bg-white/30 sm:h-14 sm:w-14"
        aria-label="Next service"
      >
        <ChevronRight class="h-5 w-5" aria-hidden="true" />
      </button>

      <div
        class="swiper services-swiper overflow-visible px-1 pb-2 sm:px-8 lg:px-12"
      >
        <div class="swiper-wrapper">
          {
            services.map((service, index) => (
              <div class="swiper-slide">
                <a href={`/services/${service.id}`} class="group block h-full">
                  <article
                    class="relative h-[420px] overflow-hidden rounded-[2px] bg-slate-200 shadow-[0_22px_45px_rgba(15,23,42,0.22)] sm:h-[460px]"
                    data-animate="fade-up"
                    data-animate-delay={`${Math.min(index, 2) * 0.1}`}
                  >
                    <img
                      src={service.data.image}
                      alt={service.data.imageAlt}
                      class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/25 to-slate-950/10" />

                    <div class="service-card-copy">
                      <h3>{service.data.title}</h3>
                      <p>{service.data.description}</p>
                    </div>
                  </article>
                </a>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import Swiper from "swiper";
  import { Navigation } from "swiper/modules";

  const servicesSection = document.querySelector(".services-section");
  const servicesSwiper = servicesSection?.querySelector(".services-swiper");
  const servicesNext = servicesSection?.querySelector(".services-next");
  const servicesPrev = servicesSection?.querySelector(".services-prev");

  if (servicesSwiper && servicesNext && servicesPrev) {
    new Swiper(servicesSwiper, {
    modules: [Navigation],
    loop: true,
    speed: 700,
    spaceBetween: 18,
    navigation: {
      nextEl: servicesNext,
      prevEl: servicesPrev,
    },
    breakpoints: {
      0: {
        slidesPerView: 1.08,
      },
      640: {
        slidesPerView: 1.4,
      },
      768: {
        slidesPerView: 2,
      },
      1024: {
        slidesPerView: 3,
      },
      1280: {
        slidesPerView: 3,
      },
    },
  });
  }
</script>

<style>
  .services-section {
    isolation: isolate;
  }
</style>
