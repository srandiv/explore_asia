---
import { MessageCircle, X } from "@lucide/astro";
import { siWhatsapp } from "simple-icons";

const whatsappText = encodeURIComponent(
  "Hello Sri Lanka Classy Tours, I would like to inquire about a tour.",
);

const socialLinks = [
  {
    label: "WhatsApp",
    href: `https://wa.me/940000000000?text=${whatsappText}`,
    icon: "whatsapp",
  },
  {
    label: "Instagram",
    href: "https://instagram.com",
    icon: "instagram",
  },
  {
    label: "Twitter",
    href: "https://twitter.com",
    icon: "twitter",
  },
  {
    label: "Facebook",
    href: "https://facebook.com",
    icon: "facebook",
  },
];
---

<div class="social-speed-dial" data-social-speed-dial>
  <div class="social-speed-dial-links" id="social-speed-dial-links">
    {
      socialLinks.map((link) => (
        <a
          class="social-speed-dial-link"
          href={link.href}
          target="_blank"
          rel="noopener"
          aria-label={link.label}
        >
          {link.icon === "instagram" && (
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
              <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="2"></rect>
              <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"></circle>
              <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"></circle>
            </svg>
          )}
          {link.icon === "twitter" && (
            <svg aria-hidden="true" viewBox="0 0 16 16" fill="currentColor">
              <path d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.142 0-.284-.009-.425A6.681 6.681 0 0 0 16 3.542a6.578 6.578 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03 9.325 9.325 0 0 1 1.108 2.6a3.289 3.289 0 0 0 1.016 4.381A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.633 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.618-.059 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58 6.32 6.32 0 0 1 0 13.535 9.344 9.344 0 0 0 5.026 15Z"></path>
            </svg>
          )}
          {link.icon === "facebook" && (
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22 12.06C22 6.505 17.523 2 12 2S2 6.505 2 12.06c0 5.02 3.657 9.184 8.438 9.94v-7.03H7.898v-2.91h2.54V9.845c0-2.522 1.492-3.915 3.777-3.915 1.094 0 2.238.197 2.238.197v2.476h-1.26c-1.243 0-1.63.776-1.63 1.572v1.886h2.773l-.443 2.91h-2.33V22C18.343 21.244 22 17.08 22 12.06Z"></path>
            </svg>
          )}
          {link.icon === "whatsapp" && (
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor">
              <path d={siWhatsapp.path}></path>
            </svg>
          )}
        </a>
      ))
    }
  </div>

  <button
    class="social-speed-dial-toggle"
    type="button"
    aria-label="Open social links"
    aria-expanded="false"
    aria-controls="social-speed-dial-links"
    data-social-speed-dial-toggle
  >
    <MessageCircle class="social-speed-dial-message-icon" aria-hidden="true" />
    <X class="social-speed-dial-close-icon" aria-hidden="true" />
  </button>
</div>

<script>
  const dial = document.querySelector("[data-social-speed-dial]");
  const toggle = dial?.querySelector("[data-social-speed-dial-toggle]");

  const setOpen = (isOpen) => {
    dial?.classList.toggle("is-open", isOpen);
    toggle?.setAttribute("aria-expanded", String(isOpen));
    toggle?.setAttribute("aria-label", isOpen ? "Close social links" : "Open social links");
  };

  toggle?.addEventListener("click", () => {
    setOpen(!dial?.classList.contains("is-open"));
  });

  document.addEventListener("click", (event) => {
    if (dial && !dial.contains(event.target)) {
      setOpen(false);
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      setOpen(false);
    }
  });
</script>
