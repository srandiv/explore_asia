---
import { ChevronLeft, ChevronRight, Star } from "@lucide/astro";
import { getCollection } from "astro:content";
import backgroundImage from "../assets/images/sri-lanka-unsplash-sigiriya.jpg";

const testimonials = (await getCollection("testimonials")).sort((a, b) => a.data.order - b.data.order);

const truncateWords = (text: string, limit: number) => {
  const words = text.trim().split(/\s+/);
  if (words.length <= limit) return text;
  return `${words.slice(0, limit).join(" ")}...`;
};
---

<section id="testimonials" class="testimonials-section relative overflow-hidden py-16 sm:py-20 lg:py-24">
  <img
    src={backgroundImage.src}
    alt=""
    aria-hidden="true"
    class="absolute inset-0 h-full w-full object-cover object-center"
  />
  <div class="absolute inset-0 bg-slate-950/32"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,244,214,0.42),rgba(255,244,214,0)_32%),linear-gradient(180deg,rgba(15,23,42,0.18)_0%,rgba(15,23,42,0.08)_38%,rgba(15,23,42,0.3)_100%)]"></div>

  <div class="relative mx-auto max-w-7xl px-6 md:px-16 lg:px-24">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-white/75">Testimonials</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl lg:text-[2.9rem]">
        Traveler Reviews
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-sm leading-7 text-white/78 sm:text-base">
        Real stories from travelers who explored Sri Lanka with us.
      </p>
    </div>

    <div class="relative mt-10">
      <button
        type="button"
        class="testimonials-prev absolute left-0 top-1/2 z-20 inline-flex h-12 w-12 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full border border-white/50 bg-white/20 text-white shadow-[0_10px_25px_rgba(15,23,42,0.2)] backdrop-blur-md transition hover:bg-white/30 sm:h-14 sm:w-14"
        aria-label="Previous testimonial"
      >
        <ChevronLeft class="h-5 w-5" aria-hidden="true" />
      </button>

      <button
        type="button"
        class="testimonials-next absolute right-0 top-1/2 z-20 inline-flex h-12 w-12 translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full border border-white/50 bg-white/20 text-white shadow-[0_10px_25px_rgba(15,23,42,0.2)] backdrop-blur-md transition hover:bg-white/30 sm:h-14 sm:w-14"
        aria-label="Next testimonial"
      >
        <ChevronRight class="h-5 w-5" aria-hidden="true" />
      </button>

      <div class="swiper testimonials-swiper overflow-visible px-1 pb-2 sm:px-10 lg:px-14">
        <div class="swiper-wrapper items-stretch">
          {
            testimonials.map((testimonial) => (
              <div class="swiper-slide h-auto">
                <article class="flex h-full min-h-[300px] flex-col rounded-[1.15rem] border border-slate-200 bg-white p-6 text-slate-700 shadow-[0_18px_40px_rgba(15,23,42,0.14)] sm:min-h-[320px]">
                  <div class="flex items-center gap-1 text-[#f2c94c]">
                    {
                      Array.from({ length: 5 }).map(() => (
                        <Star class="h-4 w-4 fill-current stroke-current" aria-hidden="true" />
                      ))
                    }
                  </div>

                  <p class="mt-4 line-clamp-4 text-[0.96rem] leading-7 text-slate-700 sm:text-[1rem]">
                    {truncateWords(testimonial.data.quote, 28)}
                  </p>

                  <div class="mt-5 border-t border-slate-200 pt-4">
                    <h3 class="text-lg font-semibold tracking-tight text-slate-900">{testimonial.data.name}</h3>
                    <p class="mt-1 text-sm text-slate-500">{testimonial.data.location}</p>
                  </div>
                </article>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import Swiper from "swiper";
  import { Navigation } from "swiper/modules";

  new Swiper(".testimonials-swiper", {
    modules: [Navigation],
    loop: true,
    speed: 700,
    spaceBetween: 18,
    navigation: {
      nextEl: ".testimonials-next",
      prevEl: ".testimonials-prev",
    },
    breakpoints: {
      0: {
        slidesPerView: 1.08,
      },
      640: {
        slidesPerView: 1.6,
      },
      900: {
        slidesPerView: 2.2,
      },
      1200: {
        slidesPerView: 3,
      },
    },
  });
</script>

<style>
  .testimonials-section {
    isolation: isolate;
  }
</style>
