---
import {
  BadgeCheck,
  Bus,
  CircleDollarSign,
  Headphones,
  HeartHandshake,
  Map,
  ShieldCheck,
  Sparkles,
  UsersRound,
} from "@lucide/astro";

const values = [
  {
    title: "Trusted B2B DMC Partner",
    text: "We support international travel agents, tour operators, and travel partners with reliable destination management, fast responses, and strong operational care.",
    icon: ShieldCheck,
  },
  {
    title: "Cost-Effective Travel Solutions",
    text: "Our in-house transportation services and professional guides help reduce third-party costs, giving partners and guests competitive rates without compromising quality.",
    icon: CircleDollarSign,
  },
  {
    title: "Experienced Leadership",
    text: "Led by a Managing Director with deep tourism and customer care experience, every journey is handled with practical knowledge and international understanding.",
    icon: UsersRound,
  },
  {
    title: "Every Journey Matters",
    text: "From airport arrival to the final farewell, we carefully manage each movement so guests enjoy smooth, memorable, and comfortable tours.",
    icon: HeartHandshake,
  },
];

const promises = [
  { label: "Professional Destination Management", icon: Map },
  { label: "Personalized Travel Experiences", icon: Sparkles },
  { label: "Luxury & Budget-Friendly Solutions", icon: BadgeCheck },
  { label: "Reliable Transport & Expert Guides", icon: Bus },
  { label: "24/7 Customer Support", icon: Headphones },
  { label: "Memorable Journeys Across Sri Lanka & Asia", icon: ShieldCheck },
];
---

<section class="site-section bg-slate-50">
  <div class="section-container">
    <div class="section-heading" data-animate="fade-up">
      <p>Why Travel With Us</p>
      <h2>Our values shape every journey</h2>
      <p>
        Explore Asia Travels combines trusted B2B destination management with
        careful local operation, personal attention, and value-focused travel
        planning across Sri Lanka and Asia.
      </p>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {
        values.map((item, index) => {
          const Icon = item.icon;

          return (
            <article
              class="h-full bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.08)]"
              data-animate="fade-up"
              data-animate-delay={Math.min(index, 3) * 0.08}
            >
              <Icon class="h-9 w-9 text-brand-secondary" aria-hidden="true" />
              <h3 class="mt-5 text-2xl text-slate-800">{item.title}</h3>
              <p class="mt-3 text-base leading-7 text-slate-600">{item.text}</p>
            </article>
          );
        })
      }
    </div>

    <div
      class="mt-10 grid gap-8 bg-white p-6 shadow-[0_18px_45px_rgba(15,23,42,0.08)] lg:grid-cols-[0.78fr_1.22fr] lg:items-center lg:p-8"
      data-animate="fade-up"
      data-animate-delay="0.12"
    >
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.24em] text-brand-primary">
          Our Promise
        </p>
        <h3 class="mt-3 text-3xl text-slate-800">Explore Beyond Expectations</h3>
        <p class="mt-4 text-base leading-7 text-slate-600">
          Your comfort, happiness, and satisfaction are always our priority. We
          manage each detail with professionalism, flexibility, and care.
        </p>
      </div>

      <div class="grid gap-3 sm:grid-cols-2">
        {
          promises.map((item) => {
            const Icon = item.icon;

            return (
              <div class="flex items-center gap-3 border border-slate-200 bg-slate-50 p-4">
                <span class="grid h-10 w-10 shrink-0 place-items-center bg-brand-secondary/10 text-brand-secondary">
                  <Icon class="h-5 w-5" aria-hidden="true" />
                </span>
                <p class="text-sm font-semibold leading-6 text-slate-800">
                  {item.label}
                </p>
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</section>
