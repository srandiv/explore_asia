---
import Footer from "../components/Footer.astro";
import FloatingActions from "../components/FloatingActions.astro";
import SocialSpeedDial from "../components/SocialSpeedDial.astro";
import {
  absoluteUrl,
  cleanJsonLd,
  siteName,
  type JsonLd,
} from "../lib/seo";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
  imageAlt?: string;
  type?: "website" | "article";
  noindex?: boolean;
  jsonLd?: JsonLd[];
}

const {
  title = "Sri Lanka Tours, Asia Holidays & B2B DMC Services",
  description = "Explore Asia Travels creates private Sri Lanka tour packages, Maldives holidays, India journeys, and reliable B2B destination management support for travel agents.",
  canonicalPath = Astro.url.pathname,
  image = "/favicon.png",
  imageAlt = "Explore Asia Travels",
  type = "website",
  noindex = false,
  jsonLd = [],
} = Astro.props;

const pageTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const canonicalUrl = absoluteUrl(canonicalPath);
const socialImage = absoluteUrl(image);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    {
      jsonLd.map((schema) => (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(cleanJsonLd(schema))}
        />
      ))
    }
  </head>
  <body class="m-0 p-0">
    <slot />
    <Footer />
    <SocialSpeedDial />
    <FloatingActions />
    <script>
      import "../scripts/animations";
    </script>
  </body>
</html>
