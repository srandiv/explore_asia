---
import { getCollection, getEntry, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";

export async function getStaticPaths() {
  const packages = await getCollection("packages");

  return packages.map((entry) => ({
    params: { slug: entry.id },
  }));
}

const entry = await getEntry("packages", Astro.params.slug);

if (!entry) {
  throw new Error(`Missing package entry for slug: ${Astro.params.slug}`);
}

const { Content } = await render(entry);
---

<Layout>
  <Navbar />

  <main class="min-h-screen bg-white px-6 pb-16 pt-32 md:px-16 lg:px-24">
    <article class="mx-auto max-w-5xl overflow-hidden bg-white shadow-[0_18px_40px_rgba(15,23,42,0.08)]">
      <img
        src={entry.data.image}
        alt={entry.data.imageAlt}
        class="h-[320px] w-full object-cover sm:h-[420px]"
      />

      <div class="p-6 sm:p-10">
        <a href="/packages" class="text-sm font-medium text-brand-blue transition-colors hover:text-slate-800">
          Back to packages
        </a>
        <p class="mt-5 text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Tour Package</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-800 sm:text-5xl">
          {entry.data.title}
        </h1>
        <p class="mt-4 max-w-3xl text-base leading-7 text-slate-600">
          {entry.data.description}
        </p>

        <div class="prose prose-slate mt-8 max-w-none prose-headings:tracking-tight prose-a:text-brand-blue">
          <Content />
        </div>
      </div>
    </article>
  </main>
</Layout>
