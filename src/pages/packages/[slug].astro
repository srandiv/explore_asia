---
import { getCollection, getEntry, render } from "astro:content";
import { ArrowLeft, ArrowRight } from "@lucide/astro";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import PageHeader from "../../components/PageHeader.astro";
import PackageCta from "../../components/PackageCta.astro";
import { getIndiaMarketPrice } from "../../lib/packagePricing";
import {
  absoluteUrl,
  breadcrumbJsonLd,
  organizationJsonLd,
  webpageJsonLd,
  websiteJsonLd,
} from "../../lib/seo";

export async function getStaticPaths() {
  const packages = await getCollection("packages");

  return packages.map((entry) => ({
    params: { slug: entry.id },
  }));
}

const entry = await getEntry("packages", Astro.params.slug);

if (!entry) {
  throw new Error(`Missing package entry for slug: ${Astro.params.slug}`);
}

const { Content } = await render(entry);
const hasPackageDetails = Boolean(
  entry.data.duration ||
    entry.data.price ||
    entry.data.inclusions?.length ||
    entry.data.complimentary?.length ||
    entry.data.itinerary?.length ||
    entry.data.gallery?.length,
);
const gallery = entry.data.gallery ?? [];
const indiaMarketPrice = entry.data.price ? getIndiaMarketPrice(entry.data.price.amount) : undefined;
const canonicalPath = `/packages/${entry.id}`;
const seoTitle = `${entry.data.title} Sri Lanka Tour Package${
  entry.data.duration ? ` - ${entry.data.duration}` : ""
}`;
const seoDescription = `${entry.data.description} Explore private transport, hotels, guides, inclusions, daily itinerary, and custom Sri Lanka travel support.`;
const packagePrice = entry.data.price?.amount.replace(/[^0-9.]/g, "");
const packageJsonLd = {
  "@context": "https://schema.org",
  "@type": "TouristTrip",
  "@id": `${absoluteUrl(canonicalPath)}#tour`,
  name: entry.data.title,
  description: entry.data.description,
  image: absoluteUrl(entry.data.image),
  url: absoluteUrl(canonicalPath),
  touristType: ["Private travelers", "Families", "Couples", "Groups", "Travel agents"],
  provider: {
    "@id": "https://www.exploreasiatravels.com/#organization",
  },
  itinerary: entry.data.itinerary?.length
    ? {
        "@type": "ItemList",
        itemListElement: entry.data.itinerary.map((day, index) => ({
          "@type": "ListItem",
          position: index + 1,
          name: `${day.day}: ${day.route}`,
          description: day.description,
        })),
      }
    : undefined,
  offers: packagePrice
    ? {
        "@type": "Offer",
        priceCurrency: "USD",
        price: packagePrice,
        availability: "https://schema.org/InStock",
        url: absoluteUrl(canonicalPath),
      }
    : undefined,
  additionalProperty: entry.data.duration
    ? [
        {
          "@type": "PropertyValue",
          name: "Duration",
          value: entry.data.duration,
        },
      ]
    : undefined,
};
---

<Layout
  title={seoTitle}
  description={seoDescription}
  canonicalPath={canonicalPath}
  image={entry.data.image}
  imageAlt={entry.data.imageAlt}
  jsonLd={[
    organizationJsonLd(),
    websiteJsonLd(),
    webpageJsonLd({
      title: seoTitle,
      description: seoDescription,
      path: canonicalPath,
      image: entry.data.image,
    }),
    breadcrumbJsonLd([
      { name: "Home", path: "/" },
      { name: "Packages", path: "/packages" },
      { name: entry.data.title, path: canonicalPath },
    ]),
    packageJsonLd,
  ]}
>
  <Navbar />

  <PageHeader
    eyebrow="Tour Package"
    title={entry.data.title}
    subtitle={entry.data.description}
    image={entry.data.image}
    imageAlt={entry.data.imageAlt}
  />

  <main class="inner-page">
    <section class="site-section">
      <div class="section-container">
        {
          hasPackageDetails ? (
            <>
              <div class="package-detail-layout">
                <aside class="package-summary-card" data-animate="fade-right" data-animate-delay="0.08">
                  <div class="package-summary-heading">
                    <p data-role="eyebrow">Tour Package</p>
                    <h2>{entry.data.title}</h2>
                    {entry.data.duration && <p data-role="duration">{entry.data.duration}</p>}
                  </div>

                  {entry.data.price && (
                    <div
                      class="package-price"
                      data-discount-market="india"
                      data-standard-price={entry.data.price.amount}
                      data-discount-price={indiaMarketPrice}
                    >
                      {indiaMarketPrice && (
                        <span data-role="market-offer" hidden>India traveller special price</span>
                      )}
                      <p>{entry.data.price.label}</p>
                      {indiaMarketPrice && (
                        <span data-role="standard-price" hidden>{entry.data.price.amount}</span>
                      )}
                      <strong data-role="price-amount">{entry.data.price.amount}</strong>
                      {entry.data.price.note && <span>{entry.data.price.note}</span>}
                    </div>
                  )}

                  {entry.data.inclusions?.length && (
                    <div class="package-list-block">
                      <h3>Included</h3>
                      <ul>
                        {entry.data.inclusions.map((item) => (
                          <li>{item}</li>
                        ))}
                      </ul>
                    </div>
                  )}

                  {entry.data.complimentary?.length && (
                    <div class="package-list-block" data-accent="secondary">
                      <h3>Complimentary from us</h3>
                      <ul>
                        {entry.data.complimentary.map((item) => (
                          <li>{item}</li>
                        ))}
                      </ul>
                    </div>
                  )}
                </aside>

                <article class="package-itinerary" data-animate="fade-up" data-animate-delay="0.14">
                  <div class="section-heading" data-align="left">
                    <p>Daily Itinerary</p>
                    <h2>How the journey unfolds</h2>
                    <p>
                      A clear day-by-day route with arrivals, sightseeing, beach time, and departure
                      planning already mapped out.
                    </p>
                  </div>

                  {gallery.length > 0 && (
                    <section class="package-gallery">
                      <div class="swiper package-gallery-swiper">
                        <div class="swiper-wrapper">
                          {gallery.map((item) => (
                            <figure class="swiper-slide package-gallery-slide">
                              <img src={item.image} alt={item.imageAlt} loading="lazy" />
                            </figure>
                          ))}
                        </div>

                        {gallery.length > 1 && (
                          <>
                            <button
                              type="button"
                              class="package-gallery-prev package-gallery-arrow"
                              aria-label="Previous package image"
                            >
                              <ArrowLeft class="h-4 w-4" aria-hidden="true" />
                            </button>
                            <button
                              type="button"
                              class="package-gallery-next package-gallery-arrow"
                              aria-label="Next package image"
                            >
                              <ArrowRight class="h-4 w-4" aria-hidden="true" />
                            </button>
                          </>
                        )}
                      </div>
                    </section>
                  )}

                  {entry.data.itinerary?.length ? (
                    <div class="package-day-list">
                      {entry.data.itinerary.map((day, index) => (
                        <section
                          class="package-day-card"
                          data-animate="fade-left"
                          data-animate-delay={Math.min(index, 5) * 0.08}
                        >
                          <div class="package-day-label">
                            <span>{day.day}</span>
                          </div>
                          <div class="package-day-copy">
                            <h3>{day.route}</h3>
                            <p>{day.description}</p>
                            {day.stay && <p data-role="stay">{day.stay}</p>}
                            {day.note && <p data-role="note">{day.note}</p>}
                          </div>
                        </section>
                      ))}
                    </div>
                  ) : (
                    <div class="content-body">
                      <Content />
                    </div>
                  )}
                </article>
              </div>

              <PackageCta packageTitle={entry.data.title} image={entry.data.image} />

            </>
          ) : (
            <>
              <article class="content-panel mx-auto max-w-4xl" data-animate="fade-up">
                <div class="content-body">
                  <Content />
                </div>
              </article>

              <PackageCta
                packageTitle={entry.data.title}
                image={entry.data.image}
                class="mx-auto mt-10 max-w-4xl"
              />
            </>
          )
        }
      </div>
    </section>
  </main>

  <script>
    import Swiper from "swiper";
    import { Navigation } from "swiper/modules";

    const packageGallery = document.querySelector(".package-gallery-swiper");
    const packageGalleryNext = document.querySelector(".package-gallery-next");
    const packageGalleryPrev = document.querySelector(".package-gallery-prev");

    if (packageGallery && packageGalleryNext && packageGalleryPrev) {
      new Swiper(packageGallery, {
        modules: [Navigation],
        loop: true,
        speed: 700,
        slidesPerView: 1,
        spaceBetween: 0,
        navigation: {
          nextEl: packageGalleryNext,
          prevEl: packageGalleryPrev,
        },
      });
    }

    const packagePrice = document.querySelector("[data-discount-market='india']");

    if (packagePrice) {
      const params = new URLSearchParams(window.location.search);
      const isIndiaMarketOffer = params.get("market") === "india";
      const discountPrice = packagePrice.getAttribute("data-discount-price");
      const priceAmount = packagePrice.querySelector("[data-role='price-amount']");
      const standardPrice = packagePrice.querySelector("[data-role='standard-price']");
      const offerNote = packagePrice.querySelector("[data-role='market-offer']");

      if (isIndiaMarketOffer && discountPrice && priceAmount) {
        packagePrice.classList.add("is-market-offer");
        priceAmount.textContent = discountPrice;

        if (standardPrice) {
          standardPrice.removeAttribute("hidden");
        }

        if (offerNote) {
          offerNote.removeAttribute("hidden");
        }
      }
    }
  </script>
</Layout>
