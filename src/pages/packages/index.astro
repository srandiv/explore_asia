---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import PageHeader from "../../components/PageHeader.astro";

const packages = (await getCollection("packages")).sort((a, b) => a.data.order - b.data.order);
---

<Layout>
  <Navbar />

  <PageHeader
    eyebrow="Tour Packages"
    title="Sri Lanka journeys with room to explore"
    subtitle="Browse flexible routes across beaches, culture, wildlife, hill country, and slower hidden corners of the island."
    image={packages[0].data.image}
    imageAlt={packages[0].data.imageAlt}
  />

  <main class="inner-page">
    <section class="site-section">
      <div class="section-container">
        <div class="section-heading" data-animate="fade-up">
          <p>Our Packages</p>
          <h2>Choose your style of escape</h2>
          <p>
            Start with a route you like, then we adjust the pace, stays, and experiences around you.
          </p>
        </div>

        <div class="page-grid mt-10">
        {
          packages.map((pkg, index) => (
            <a
              href={`/packages/${pkg.id}`}
              class="page-card"
              data-animate="fade-up"
              data-animate-delay={Math.min(index, 5) * 0.08}
            >
              <article>
                <div class="page-card-media">
                  <img
                    src={pkg.data.image}
                    alt={pkg.data.imageAlt}
                    loading="lazy"
                  />
                </div>
                <div class="page-card-content">
                  <p data-role="eyebrow">Tour Package</p>
                  <h2>{pkg.data.title}</h2>
                  <p>{pkg.data.description}</p>
                </div>
              </article>
            </a>
          ))
        }
      </div>
      </div>
    </section>
  </main>
</Layout>
