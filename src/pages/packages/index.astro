---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import PageHeader from "../../components/PageHeader.astro";
import {
  breadcrumbJsonLd,
  itemListJsonLd,
  organizationJsonLd,
  webpageJsonLd,
  websiteJsonLd,
} from "../../lib/seo";

const packages = (await getCollection("packages")).sort((a, b) => a.data.order - b.data.order);
const title = "Sri Lanka Tour Packages and Private Itineraries";
const description =
  "Browse private Sri Lanka tour packages with cultural triangle routes, beaches, wildlife safaris, hill country, Colombo, hotels, transport, guides, and flexible pacing.";
---

<Layout
  title={title}
  description={description}
  canonicalPath="/packages"
  image={packages[0].data.image}
  imageAlt={packages[0].data.imageAlt}
  jsonLd={[
    organizationJsonLd(),
    websiteJsonLd(),
    webpageJsonLd({ title, description, path: "/packages", image: packages[0].data.image }),
    breadcrumbJsonLd([
      { name: "Home", path: "/" },
      { name: "Packages", path: "/packages" },
    ]),
    itemListJsonLd(
      packages.map((pkg) => ({
        name: pkg.data.title,
        description: pkg.data.description,
        image: pkg.data.image,
        path: `/packages/${pkg.id}`,
      })),
    ),
  ]}
>
  <Navbar />

  <PageHeader
    eyebrow="Tour Packages"
    title="Sri Lanka journeys with room to explore"
    subtitle="Browse flexible routes across beaches, culture, wildlife, hill country, and slower hidden corners of the island."
    image={packages[0].data.image}
    imageAlt={packages[0].data.imageAlt}
  />

  <main class="inner-page">
    <section class="site-section">
      <div class="section-container">
        <div class="section-heading" data-animate="fade-up">
          <p>Our Packages</p>
          <h2>Choose your style of escape</h2>
          <p>
            Start with a route you like, then we adjust the pace, stays, and experiences around you.
          </p>
        </div>

        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row" data-animate="fade-up">
          <a href="/sri-lanka-tour-packages" class="site-button">Sri Lanka tour planning</a>
          <a href="/b2b-sri-lanka-dmc" class="site-button bg-brand-dark hover:bg-brand-secondary">
            B2B DMC support
          </a>
        </div>

        <div class="page-grid mt-10">
        {
          packages.map((pkg, index) => (
            <a
              href={`/packages/${pkg.id}`}
              class="page-card"
              data-animate="fade-up"
              data-animate-delay={Math.min(index, 5) * 0.08}
            >
              <article>
                <div class="page-card-media">
                  <img
                    src={pkg.data.image}
                    alt={pkg.data.imageAlt}
                    loading="lazy"
                  />
                </div>
                <div class="page-card-content">
                  <p data-role="eyebrow">Tour Package</p>
                  <h2>{pkg.data.title}</h2>
                  <p>{pkg.data.description}</p>
                </div>
              </article>
            </a>
          ))
        }
      </div>
      </div>
    </section>
  </main>
</Layout>
