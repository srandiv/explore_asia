---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import PageHeader from "../components/PageHeader.astro";
import {
  breadcrumbJsonLd,
  organizationJsonLd,
  webpageJsonLd,
  websiteJsonLd,
} from "../lib/seo";

const headerImage =
  "https://images.unsplash.com/photo-1586000695819-7dbe14384ba3?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D";
const title = "Privacy Policy";
const description =
  "Read how Explore Asia Travels handles personal information shared for travel inquiries, quotes, bookings, and Sri Lanka or Asia trip planning support.";
---

<Layout
  title={title}
  description={description}
  canonicalPath="/privacy-policy"
  image={headerImage}
  imageAlt="A calm Sri Lankan beach at sunset"
  jsonLd={[
    organizationJsonLd(),
    websiteJsonLd(),
    webpageJsonLd({ title, description, path: "/privacy-policy", image: headerImage }),
    breadcrumbJsonLd([
      { name: "Home", path: "/" },
      { name: "Privacy Policy", path: "/privacy-policy" },
    ]),
  ]}
>
  <Navbar />

  <PageHeader
    eyebrow="Legal"
    title="Privacy Policy"
    subtitle="How Explore Asia handles the details you share when planning a trip with us."
    image={headerImage}
    imageAlt="A calm Sri Lankan beach at sunset"
  />

  <main class="inner-page">
    <section class="site-section">
      <div class="section-container">
        <div class="content-body mx-auto max-w-4xl" data-animate="fade-up">
        <p>
          Explore Asia respects your privacy and handles personal information carefully when you contact us, request quotes,
          or make travel arrangements.
        </p>
        <p>
          We may collect basic details such as your name, email address, phone number, and travel preferences to help us
          provide quotes, confirm bookings, and support your trip.
        </p>
        <p>
          We do not sell your personal information. Any data shared with trusted service partners is used only to complete
          your booking or deliver requested travel services.
        </p>
        <p>
          By using this website, you agree that we may process your information as needed to respond to inquiries, manage
          reservations, and improve our services.
        </p>
        </div>
      </div>
    </section>
  </main>
</Layout>
