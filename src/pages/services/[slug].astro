---
import { getCollection, getEntry, render } from "astro:content";
import { ArrowLeft, CheckCircle2 } from "@lucide/astro";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import PageHeader from "../../components/PageHeader.astro";

export async function getStaticPaths() {
  const services = await getCollection("services");

  return services.map((entry) => ({
    params: { slug: entry.id },
  }));
}

const entry = await getEntry("services", Astro.params.slug);

if (!entry) {
  throw new Error(`Missing service entry for slug: ${Astro.params.slug}`);
}

const { Content } = await render(entry);
const options = entry.data.options ?? [];
const gallery = entry.data.gallery ?? [];
---

<Layout>
  <Navbar />

  <PageHeader
    eyebrow="Service"
    title={entry.data.title}
    subtitle={entry.data.description}
    image={entry.data.image}
    imageAlt={entry.data.imageAlt}
  />

  <main class="inner-page">
    <section class="service-detail-section">
      <div class="section-container">
        <article class="service-detail content-panel" data-animate="fade-up">
          <a href="/services" class="back-link">
            <ArrowLeft aria-hidden="true" />
            Back to services
          </a>

          <div class="service-detail-grid">
            <div class="content-body">
              <Content />
            </div>

            {options.length > 0 && (
              <aside class="service-options" data-animate="fade-left" data-animate-delay="0.12">
                <p data-role="eyebrow">Options</p>
                <h2>What we can arrange</h2>
                <ul>
                  {options.map((option) => (
                    <li>
                      <CheckCircle2 aria-hidden="true" />
                      <span>{option}</span>
                    </li>
                  ))}
                </ul>
              </aside>
            )}
          </div>

          {gallery.length > 0 && (
            <section class="service-gallery" aria-labelledby="service-gallery-title">
              <div class="section-heading mx-auto text-center" data-animate="fade-up">
                <p>Gallery</p>
                <h2 id="service-gallery-title">{entry.data.title} moments</h2>
              </div>

              <div class="service-gallery-grid">
                {gallery.map((item, index) => (
                  <figure data-animate="fade-up" data-animate-delay={String(index * 0.08)}>
                    <img src={item.image} alt={item.imageAlt} loading="lazy" />
                  </figure>
                ))}
              </div>
            </section>
          )}
        </article>
      </div>
    </section>
  </main>
</Layout>
