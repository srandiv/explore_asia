---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";

const services = (await getCollection("services")).sort((a, b) => a.data.order - b.data.order);
---

<Layout>
  <Navbar />

  <main class="min-h-screen bg-[#dceaea] px-6 pb-16 pt-32 md:px-16 lg:px-24">
    <div class="mx-auto max-w-7xl">
      <p class="text-sm font-semibold uppercase tracking-[0.28em] text-slate-600">Our Services</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-800 sm:text-5xl">Explore what we can arrange for your trip</h1>
      <p class="mt-4 max-w-3xl text-sm leading-7 text-slate-600 sm:text-base">
        Each service below is powered by the same content collection that drives the homepage carousel, so you can add full pages later without changing the data model.
      </p>

      <div class="mt-10 grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
        {
          services.map((service) => (
            <a href={`/services/${service.id}`} class="group block">
              <article class="overflow-hidden bg-white shadow-[0_18px_40px_rgba(15,23,42,0.08)] transition-transform duration-300 group-hover:-translate-y-1">
                <img
                  src={service.data.image}
                  alt={service.data.imageAlt}
                  class="h-64 w-full object-cover"
                  loading="lazy"
                />
                <div class="p-6">
                  <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Service</p>
                  <h2 class="mt-3 text-2xl font-semibold tracking-tight text-slate-800">{service.data.title}</h2>
                  <p class="mt-3 text-sm leading-6 text-slate-600">{service.data.description}</p>
                </div>
              </article>
            </a>
          ))
        }
      </div>
    </div>
  </main>
</Layout>
