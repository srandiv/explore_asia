---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import PageHeader from "../../components/PageHeader.astro";
import { resolveContentImage } from "../../lib/contentImages";
import {
  breadcrumbJsonLd,
  itemListJsonLd,
  organizationJsonLd,
  webpageJsonLd,
  websiteJsonLd,
} from "../../lib/seo";

const services = (await getCollection("services")).sort((a, b) => a.data.order - b.data.order);

const headerImage =
  "https://images.unsplash.com/photo-1623595289196-007a22dd8560?q=80&w=1374&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D";
const title = "Sri Lanka Travel Services, B2B DMC Support and Ground Handling";
const description =
  "Explore Sri Lanka travel services including B2B DMC support, hotels, private transport, sightseeing, guides, food experiences, visa support, and custom trip planning.";
---

<Layout
  title={title}
  description={description}
  canonicalPath="/services"
  image={headerImage}
  imageAlt="Elephant close-up in Sri Lanka"
  jsonLd={[
    organizationJsonLd(),
    websiteJsonLd(),
    webpageJsonLd({ title, description, path: "/services", image: headerImage }),
    breadcrumbJsonLd([
      { name: "Home", path: "/" },
      { name: "Services", path: "/services" },
    ]),
    itemListJsonLd(
      services.map((service) => ({
        name: service.data.title,
        description: service.data.description,
        image: resolveContentImage(service.data.image),
        path: `/services/${service.id}`,
      })),
    ),
  ]}
>
  <Navbar />

  <PageHeader
    eyebrow="Our Services"
    title="Thoughtful travel support across Sri Lanka"
    subtitle="From airport pickups and private guides to hotels, dining, sightseeing, and visa support, we shape each detail around the way you want to travel."
    image={headerImage}
    imageAlt="Elephant close-up in Sri Lanka"
    imagePosition="center 42%"
  />

  <main class="inner-page">
    <section class="site-section">
      <div class="section-container">
        <div class="section-heading" data-animate="fade-up">
          <p>Plan With Ease</p>
          <h2>Services made for smoother journeys</h2>
          <p>
            Choose the support you need, then we connect the pieces into a comfortable itinerary.
          </p>
        </div>

        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row" data-animate="fade-up">
          <a href="/b2b-sri-lanka-dmc" class="site-button">B2B Sri Lanka DMC</a>
          <a href="/sri-lanka-tour-packages" class="site-button bg-brand-dark hover:bg-brand-secondary">
            Sri Lanka tour packages
          </a>
        </div>

        <div class="page-grid mt-10">
        {
          services.map((service, index) => (
            <a
              href={`/services/${service.id}`}
              class="page-card"
              data-animate="fade-up"
              data-animate-delay={Math.min(index, 5) * 0.08}
            >
              <article>
                <div class="page-card-media">
                  <img
                    src={resolveContentImage(service.data.image)}
                    alt={service.data.imageAlt}
                    loading="lazy"
                  />
                </div>
                <div class="page-card-content">
                  <p data-role="eyebrow">Service</p>
                  <h2>{service.data.title}</h2>
                  <p>{service.data.description}</p>
                </div>
              </article>
            </a>
          ))
        }
      </div>
      </div>
    </section>
  </main>
</Layout>
