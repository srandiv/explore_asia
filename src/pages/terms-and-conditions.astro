---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import PageHeader from "../components/PageHeader.astro";

const headerImage =
  "https://images.unsplash.com/photo-1586000695819-7dbe14384ba3?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D";
---

<Layout>
  <Navbar />

  <PageHeader
    eyebrow="Legal"
    title="Terms and Conditions"
    subtitle="The basic terms for bookings, travel arrangements, documents, and service use."
    image={headerImage}
    imageAlt="A calm Sri Lankan beach at sunset"
  />

  <main class="inner-page">
    <section class="site-section">
      <div class="section-container">
        <div class="content-body mx-auto max-w-4xl" data-animate="fade-up">
        <p>
          These terms and conditions govern the use of Explore Asia services, including package bookings, custom trips,
          transportation, and related travel arrangements.
        </p>
        <p>
          All bookings are subject to availability and confirmation. Final pricing, itinerary changes, and special requests
          may depend on seasonality, supplier availability, and travel requirements.
        </p>
        <p>
          Travelers are responsible for providing accurate personal details and valid travel documents. We recommend reviewing
          cancellation, refund, and payment policies before confirming any booking.
        </p>
        <p>
          By using this website or making a reservation, you agree to the terms described here and any additional conditions
          shared during the booking process.
        </p>
        </div>
      </div>
    </section>
  </main>
</Layout>
