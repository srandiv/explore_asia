---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
---

<Layout>
  <Navbar />

  <main class="min-h-screen bg-[#f7f4ee] px-6 pb-16 pt-32 md:px-16 lg:px-24">
    <div class="mx-auto max-w-4xl">
      <p class="text-sm font-semibold uppercase tracking-[0.28em] text-slate-500">Legal</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-800 sm:text-5xl">Terms and Conditions</h1>
      <div class="mt-8 space-y-6 text-sm leading-7 text-slate-600 sm:text-base">
        <p>
          These terms and conditions govern the use of Explore Asia services, including package bookings, custom trips,
          transportation, and related travel arrangements.
        </p>
        <p>
          All bookings are subject to availability and confirmation. Final pricing, itinerary changes, and special requests
          may depend on seasonality, supplier availability, and travel requirements.
        </p>
        <p>
          Travelers are responsible for providing accurate personal details and valid travel documents. We recommend reviewing
          cancellation, refund, and payment policies before confirming any booking.
        </p>
        <p>
          By using this website or making a reservation, you agree to the terms described here and any additional conditions
          shared during the booking process.
        </p>
      </div>
    </div>
  </main>
</Layout>
